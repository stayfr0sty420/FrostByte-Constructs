<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../partials/head', { title }) %>
  </head>
  <body class="app verify-page">
    <%- include('../partials/nav') %>
    <main class="container py-4">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-7">
          <div class="card shadow-sm verify-card">
            <div class="card-body p-4">
              <h1 class="h4 mb-2">Verification</h1>
              <p class="text-muted">
                This server requires you to verify yourself to get access to other channels. Click <strong>Verify</strong> to continue.
              </p>

              <% const needsGeo = (typeof requireLocation !== 'undefined' && requireLocation) ? true : false; %>

              <% if (error === 'location_required') { %>
                <div class="alert alert-danger" id="locationError">
                  Please allow the required permissions and try again.
                </div>
              <% } %>

              <div class="alert alert-danger d-none" id="formError"></div>

              <form
                method="post"
                action="/verify/<%= guildId %>"
                data-require-geo="<%= needsGeo ? '1' : '0' %>"
                data-guild-id="<%= guildId %>"
                data-csrf="<%= csrfToken %>"
                data-token="<%= token %>"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="t" value="<%= token %>" />
                <input type="hidden" name="geoLat" id="geoLat" />
                <input type="hidden" name="geoLon" id="geoLon" />
                <input type="hidden" name="geoAcc" id="geoAcc" />
                <input type="hidden" name="publicIp" id="publicIp" />

                <% const qs = Array.isArray(questions) && questions.length ? questions : [cfg.verification.question1, cfg.verification.question2, cfg.verification.question3].filter(Boolean); %>
                <% qs.forEach((q, idx) => { %>
                  <div class="mb-3">
                    <label class="form-label"><%= q %></label>
                    <input class="form-control" name="answer<%= idx + 1 %>" />
                  </div>
                <% }) %>

                <div class="d-flex flex-wrap gap-2 align-items-center verify-actions">
                  <button class="btn btn-primary" type="submit" id="submitBtn">Verify</button>
                  <span class="text-muted small" id="geoStatus"></span>
                </div>
                <div class="text-danger small mt-2" id="ipStatus"></div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
    <script src="/assets/js/verify.js"></script>
    <%- include('../partials/footer') %>
  </body>
</html>
