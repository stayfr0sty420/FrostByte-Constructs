<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page backups-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <% if (flash) { %>
        <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <div id="backupOperationMount">
        <% if (activeOperation) { %>
          <% const activeOperationStatus = String(activeOperation.status || '').toLowerCase(); %>
          <section
            class="card shadow-sm mb-4 backup-operation-card"
            id="backupOperationCard"
            data-operation-id="<%= activeOperation.operationId %>"
            data-status="<%= activeOperation.status %>"
          >
            <div class="card-body">
              <div class="backup-operation-head mb-3">
                <div class="backup-operation-copy">
                  <div class="text-uppercase text-muted small" id="backupOperationEyebrow"><%= activeOperation.action === 'restore' ? 'Restore Progress' : 'Backup Progress' %></div>
                  <h2 class="h6 mb-1" id="backupOperationLabel"><%= activeOperation.label || 'Backup operation' %></h2>
                  <div class="text-muted small" id="backupOperationMessage"><%= activeOperation.message || 'Queued' %></div>
                </div>
                <div class="backup-operation-badges">
                  <span
                    class="backup-operation-live <%= activeOperationStatus === 'completed' ? 'is-done' : (activeOperationStatus === 'failed' ? 'is-failed' : 'is-connecting') %>"
                    id="backupOperationLiveState"
                  >
                    <span class="backup-operation-live__dot"></span>
                    <span id="backupOperationLiveLabel"><%= activeOperationStatus === 'completed' ? 'DONE' : (activeOperationStatus === 'failed' ? 'FAILED' : 'CONNECTING') %></span>
                  </span>
                  <span
                    class="badge <%= activeOperationStatus === 'completed' ? 'text-bg-success' : (activeOperationStatus === 'failed' ? 'text-bg-danger' : 'text-bg-primary') %>"
                    id="backupOperationStatus"
                  >
                    <%= activeOperation.status %>
                  </span>
                </div>
              </div>

              <div class="backup-operation-health small" id="backupOperationHealth">
                <%= activeOperationStatus === 'completed' ? 'Operation finished successfully.' : (activeOperationStatus === 'failed' ? 'Operation stopped. Review the details below.' : 'Opening live updates…') %>
              </div>

              <div class="progress mb-2" role="progressbar" aria-label="Backup progress" aria-valuemin="0" aria-valuemax="100">
                <div
                  class="progress-bar <%= activeOperation.status === 'completed' ? 'bg-success' : (activeOperation.status === 'failed' ? 'bg-danger' : 'bg-primary') %>"
                  id="backupOperationBar"
                  style="width: <%= Math.max(0, Math.min(100, Number(activeOperation.progress || 0))) %>%"
                >
                  <span id="backupOperationPercent"><%= Math.max(0, Math.min(100, Number(activeOperation.progress || 0))) %>%</span>
                </div>
              </div>

              <div class="small text-muted" id="backupOperationMeta">
                Started <%= formatDate(activeOperation.startedAt) || 'just now' %>
                <% if (activeOperation.updatedAt && activeOperationStatus === 'running') { %>
                  · Updated <%= formatDate(activeOperation.updatedAt) %>
                <% } %>
                <% if (activeOperation.completedAt) { %>
                  · Finished <%= formatDate(activeOperation.completedAt) %>
                <% } %>
                <% if (activeOperation.error) { %>
                  · <%= activeOperation.error %>
                <% } %>
              </div>
            </div>
          </section>
        <% } %>
      </div>
      <script id="backupOperationInitialData" type="application/json"><%- JSON.stringify(activeOperation || null).replace(/</g, '\\u003c') %></script>

      <% const channelNameById = new Map((channels || []).map((c) => [c.id, c.name])); %>
      <% const restorableBackups = (backups || []).filter((b) => String(b.status || '').toLowerCase() === 'completed'); %>

      <section class="backup-hero">
        <div class="backup-hero-grid">
          <div class="backup-hero-copy">
            <div class="hero-eyebrow">Backup Center</div>
            <h1 class="hero-title">Protect your server with clean restores.</h1>
            <p class="hero-text">
              Create full or selective backups, restore fast, and keep your server clean with auto‑pruning. Designed to
              stay reliable even during cross‑server recovery.
            </p>
            <div class="backup-callout">
              <strong>Cross‑server restore:</strong> restore a backup into a different server by supplying the target guild
              ID. For a full rebuild, enable <strong>Wipe first</strong> to clear existing channels/roles.
            </div>
          </div>

          <div class="backup-hero-stack">
            <div class="card backup-card">
              <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Create Backup</h2>
                <form method="post" action="/admin/backups/create" class="backup-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="row g-2">
                    <div class="col-12">
                      <input class="form-control" name="name" placeholder="Backup name (optional)" />
                    </div>
                    <div class="col-12 col-md-7">
                      <label class="form-label">Backup Types</label>
                      <div class="backup-type-grid" role="group" aria-label="Backup types">
                        <% ['full','channels','roles','messages','bans','webhooks','emojis','stickers','threads','nicknames','bots'].forEach((type) => { %>
                          <label class="backup-type-option">
                            <input class="form-check-input" type="checkbox" name="type[]" value="<%= type %>" <%= type === 'full' ? 'checked' : '' %> />
                            <span><%= type %></span>
                          </label>
                        <% }) %>
                      </div>
                      <div class="form-text">Select one or more. If <strong>full</strong> is checked, it overrides the other types automatically.</div>
                    </div>
                    <div class="col-12 col-md-5 d-flex align-items-center">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="1" id="archiveBackup" name="archive" />
                        <label class="form-check-label" for="archiveBackup">Archive</label>
                      </div>
                    </div>
                    <div class="col-12">
                      <button class="btn btn-primary w-100" type="submit">Create Backup</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>

            <div class="card backup-card">
              <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Restore Backup</h2>
                <form method="post" action="/admin/backups/restore" class="backup-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <% if (!restorableBackups.length) { %>
                    <p class="text-muted small mb-2">No completed backups are ready to restore yet.</p>
                    <button class="btn btn-outline-primary w-100" type="submit" disabled>Restore Backup</button>
                  <% } else { %>
                    <div class="row g-2">
                      <div class="col-12">
                        <select class="form-select" name="backupId" required>
                          <% restorableBackups.forEach(b => { %>
                            <option value="<%= b.backupId %>"><%= b.name || b.type %> — <%= b.backupId %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="col-12">
                        <input class="form-control" name="targetGuildId" placeholder="Target guild ID (optional)" />
                      </div>
                      <div class="col-12">
                        <div class="backup-toggle-grid">
                          <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="prune" value="1" checked />
                            <span class="form-check-label">Prune extra channels/roles</span>
                          </label>
                          <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="wipe" value="1" />
                            <span class="form-check-label">Wipe first (recommended for cross‑server)</span>
                          </label>
                          <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="restoreMessages" value="1" checked />
                            <span class="form-check-label">Restore messages</span>
                          </label>
                          <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="restoreBans" value="1" checked />
                            <span class="form-check-label">Restore bans</span>
                          </label>
                        </div>
                      </div>
                      <div class="col-12">
                        <button
                          class="btn btn-outline-primary w-100"
                          type="submit"
                          data-confirm="Restore this backup now?"
                          data-confirm-title="Restore backup?"
                          data-confirm-ok="Restore"
                          data-confirm-cancel="Cancel"
                        >
                          Restore Backup
                        </button>
                      </div>
                    </div>
                  <% } %>
                </form>
              </div>
            </div>

            <div class="card backup-card">
              <div class="card-body">
                <h2 class="h6 text-uppercase text-muted">Automated Backups</h2>
                <form method="post" action="/admin/backups/schedules" class="backup-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="row g-2">
                    <div class="col-12 col-md-6">
                      <label class="form-label">Schedule</label>
                      <select class="form-select" name="preset" id="schedulePreset" required>
                        <option value="hourly">Hourly</option>
                        <option value="daily" selected>Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="monthly">Monthly</option>
                      </select>
                      <div class="form-text">Pick a preset schedule for automated backups.</div>
                    </div>
                    <div class="col-12 col-md-6">
                      <label class="form-label">Types</label>
                      <div class="backup-type-grid" role="group" aria-label="Scheduled backup types">
                        <% ['full','channels','roles','messages','bans','webhooks','emojis','stickers','threads','nicknames','bots'].forEach((type) => { %>
                          <label class="backup-type-option">
                            <input class="form-check-input" type="checkbox" name="types[]" value="<%= type %>" <%= type === 'full' ? 'checked' : '' %> />
                            <span><%= type %></span>
                          </label>
                        <% }) %>
                      </div>
                      <div class="form-text">Pick one or more types for scheduled backups. If <strong>full</strong> is checked, that schedule runs as a full backup.</div>
                    </div>
                    <div class="col-12 col-md-6">
                      <label class="form-label">Notify Channel</label>
                      <select class="form-select" name="channelId">
                        <option value="">(none)</option>
                        <% (channels || []).forEach(c => { %>
                          <option value="<%= c.id %>"><%= c.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-12 col-md-6 d-flex align-items-center gap-3">
                      <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" name="enabled" value="1" checked />
                        <label class="form-check-label">Enabled</label>
                      </div>
                      <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" name="replacePrevious" value="1" />
                        <label class="form-check-label">Keep latest only</label>
                      </div>
                    </div>
                    <div class="col-12">
                      <button class="btn btn-outline-primary w-100" type="submit">Add Schedule</button>
                    </div>
                  </div>
                </form>

                <div class="table-responsive mt-3">
                  <table class="table table-sm align-middle mb-0">
                    <thead>
                      <tr>
                        <th>Schedule</th>
                        <th>Type</th>
                        <th>Next Run</th>
                        <th>Notify</th>
                        <th>Enabled</th>
                        <th>Latest Only</th>
                        <th class="text-end">Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (!schedules || !schedules.length) { %>
                        <tr><td colspan="7" class="text-muted small">No schedules yet.</td></tr>
                      <% } %>
                      <% (schedules || []).forEach(s => { %>
                        <tr>
                          <td>
                            <div class="fw-semibold"><%= s.label || 'Custom' %></div>
                            <div class="text-muted small"><code><%= s.interval || s.cron %></code></div>
                          </td>
                          <td><%= s.backupType %></td>
                          <td class="text-muted small"><%= formatDate(s.nextRun) || '—' %></td>
                          <td class="text-muted small"><%= channelNameById.get(s.channelId) || s.channelId || '—' %></td>
                          <td><%= s.enabled ? 'yes' : 'no' %></td>
                          <td><%= s.replacePrevious ? 'yes' : 'no' %></td>
                          <td class="text-end">
                            <form method="post" action="/admin/backups/schedules/<%= s.scheduleId %>/delete" class="d-inline">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button class="btn btn-outline-danger btn-sm icon-btn" type="submit" title="Delete schedule" aria-label="Delete schedule">🗑️</button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="card shadow-sm mb-4">
        <div class="card-body">
          <h2 class="h6 text-uppercase text-muted">Retention Policy</h2>
          <form method="post" action="/admin/backups/retention" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-4">
              <label class="form-label">Keep last (count)</label>
              <input class="form-control" name="retentionCount" type="number" min="1" step="1" value="<%= cfg?.backup?.retentionCount ?? 10 %>" />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label">Delete older than (days)</label>
              <input class="form-control" name="retentionDays" type="number" min="1" step="1" value="<%= cfg?.backup?.retentionDays ?? 30 %>" />
            </div>
            <div class="col-12 col-md-4 d-grid align-self-end">
              <button class="btn btn-outline-secondary" type="submit">Save Retention</button>
            </div>
          </form>
        </div>
      </section>

      <section class="backup-feature-grid">
        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Backup Features</h2>
          <ul class="backup-feature-list">
            <li>Full server backups</li>
            <li>Channel backups</li>
            <li>Role backups</li>
            <li>Message backups</li>
            <li>Ban list backups</li>
            <li>Emoji backups</li>
            <li>Sticker backups</li>
            <li>Webhook backups</li>
            <li>Thread backups</li>
          </ul>
        </article>

        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Server Data Protection</h2>
          <ul class="backup-feature-list">
            <li>Server settings and configuration</li>
            <li>Channels and categories w/ config</li>
            <li>Roles w/ colors, images, and permissions</li>
            <li>Bot list, info, and perms</li>
            <li>Emojis and stickers</li>
            <li>Threads</li>
            <li>Forum posts</li>
            <li>Member roles and nicknames</li>
          </ul>
        </article>

        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Message Backups</h2>
          <ul class="backup-feature-list">
            <li>Message content</li>
            <li>Attachments</li>
            <li>Webhooks</li>
            <li>Embeds</li>
            <li>Reactions</li>
            <li>Author information</li>
            <li>Timestamps</li>
          </ul>
        </article>

        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Backup Management</h2>
          <ul class="backup-feature-list">
            <li>Create backups manually</li>
            <li>Scheduled automatic backups</li>
            <li>Backup restore options</li>
            <li>Selective restore options</li>
            <li>Backup templates</li>
            <li>Backup download links</li>
          </ul>
        </article>

        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Automation</h2>
          <ul class="backup-feature-list">
            <li>Hourly / Daily / Weekly schedules</li>
            <li>Backup retention policies</li>
            <li>Automatic cleanup of old backups</li>
            <li>Revert to last known good state</li>
          </ul>
        </article>

        <article class="backup-feature-card">
          <h2 class="backup-feature-title">Storage</h2>
          <ul class="backup-feature-list">
            <li>Compressed backup archives</li>
            <li>Local storage system</li>
            <li>Optional cloud storage integration</li>
          </ul>
        </article>
      </section>

      <section class="card backup-table-card">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h5 m-0">Latest Backups</h2>
            <span class="text-muted small"><%= backups.length %> total</span>
          </div>
          <div class="table-responsive">
            <table class="table table-sm align-middle backups-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Type</th>
                  <th>Status</th>
                  <th>Size</th>
                  <th>Archived</th>
                  <th>Source</th>
                  <th>Created</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!backups.length) { %>
                  <tr>
                    <td colspan="9" class="text-muted small">No backups found yet. Create one above to get started.</td>
                  </tr>
                <% } %>
                <% backups.forEach(b => { %>
                  <tr>
                    <td data-label="ID"><code><%= b.backupId %></code></td>
                    <td data-label="Name"><span class="backup-cell-text"><%= b.name || b.type %></span></td>
                    <td data-label="Type"><span class="backup-cell-text"><%= b.type %></span></td>
                    <td data-label="Status">
                      <span class="badge backup-status-badge <%= b.status === 'completed' ? 'text-bg-success' : (b.status === 'failed' ? 'text-bg-danger' : 'text-bg-warning') %>">
                        <%= b.status %>
                      </span>
                    </td>
                    <td data-label="Size" class="text-muted small"><span class="backup-cell-text"><%= b.size ? (b.size / (1024 * 1024)).toFixed(2) + ' MB' : '0 MB' %></span></td>
                    <td data-label="Archived"><span class="backup-cell-text"><%= b.archived ? 'yes' : 'no' %></span></td>
                    <td data-label="Source">
                      <span class="badge <%= b.source === 'automated' ? 'text-bg-primary' : 'text-bg-secondary' %>"><%= b.source %></span>
                    </td>
                    <td data-label="Created" class="text-muted small"><span class="backup-cell-text"><%= formatDate(b.createdAt) || '—' %></span></td>
                    <td data-label="Actions" class="text-end">
                      <div class="backup-actions">
                        <% if (String(b.status || '').toLowerCase() === 'completed') { %>
                          <a class="btn btn-outline-secondary btn-sm icon-btn" href="/admin/backups/download/<%= b.backupId %>" title="Download" aria-label="Download">⬇️</a>
                        <% } else { %>
                          <button class="btn btn-outline-secondary btn-sm icon-btn" type="button" disabled title="Backup not ready" aria-label="Backup not ready">⬇️</button>
                        <% } %>
                        <form method="post" action="/admin/backups/restore/<%= b.backupId %>" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button
                            class="btn btn-outline-primary btn-sm icon-btn"
                            type="submit"
                            <%= String(b.status || '').toLowerCase() === 'completed' ? '' : 'disabled' %>
                            data-confirm="Restore roles/channels from this backup?"
                            data-confirm-title="Quick restore?"
                            data-confirm-ok="Restore"
                            data-confirm-cancel="Cancel"
                            title="<%= String(b.status || '').toLowerCase() === 'completed' ? 'Quick Restore' : 'Backup not ready' %>"
                            aria-label="<%= String(b.status || '').toLowerCase() === 'completed' ? 'Quick Restore' : 'Backup not ready' %>"
                          >
                            ⚡
                          </button>
                        </form>
                        <form method="post" action="/admin/backups/delete/<%= b.backupId %>" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button
                            class="btn btn-outline-danger btn-sm icon-btn"
                            type="submit"
                            data-confirm="Delete this backup?"
                            data-confirm-title="Delete backup?"
                            data-confirm-ok="Delete"
                            data-confirm-cancel="Cancel"
                            title="Delete"
                            aria-label="Delete"
                          >
                            🗑️
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
    <script>
      (() => {
        const preset = document.getElementById('schedulePreset');
        const scheduleForm = preset?.closest('form') || null;
        const createForm = document.querySelector('form[action="/admin/backups/create"]');
        if (!preset) return;

        const ensureAtLeastOneChecked = (formSelector, inputName, message) => {
          const form = formSelector;
          if (!form) return;
          form.addEventListener('submit', (event) => {
            const checked = form.querySelectorAll(`input[name="${inputName}"]:checked`);
            if (checked.length) return;
            event.preventDefault();
            window.alert(message);
          });
        };

        ensureAtLeastOneChecked(createForm, 'type[]', 'Select at least one backup type before creating a backup.');
        ensureAtLeastOneChecked(scheduleForm, 'types[]', 'Select at least one backup type before saving an automated backup schedule.');
      })();

      (() => {
        const mount = document.getElementById('backupOperationMount');
        const initialOperationEl = document.getElementById('backupOperationInitialData');
        const createForm = document.querySelector('form[action="/admin/backups/create"]');
        const restoreForms = Array.from(document.querySelectorAll('form[action="/admin/backups/restore"], form[action^="/admin/backups/restore/"]'));
        if (!mount) return;

        let initialOperation = null;
        try {
          initialOperation = JSON.parse(initialOperationEl?.textContent || 'null');
        } catch (_error) {
          initialOperation = null;
        }

        let stream = null;
        let pollTimer = null;
        let reloadScheduled = false;
        let activeOperationId = '';
        let liveTicker = null;
        let currentOperation = initialOperation && typeof initialOperation === 'object' ? initialOperation : null;
        let lastContactAt = 0;
        let transportMode = '';
        let connectionState =
          currentOperation && String(currentOperation.status || '').toLowerCase() === 'running' ? 'connecting' : 'idle';

        const escapeHtml = (value) =>
          String(value || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const statusClass = (status) => {
          const normalized = String(status || 'running').toLowerCase();
          if (normalized === 'completed') return 'success';
          if (normalized === 'failed') return 'danger';
          return 'primary';
        };

        const formatTimestamp = (value, prefix = '') => {
          const date = value ? new Date(value) : null;
          if (!date || Number.isNaN(date.getTime())) return '';
          return prefix ? `${prefix} ${date.toLocaleString()}` : date.toLocaleString();
        };

        const timestampToMs = (value) => {
          if (!value) return 0;
          if (typeof value === 'number' && Number.isFinite(value)) return value;
          const date = new Date(value);
          return Number.isNaN(date.getTime()) ? 0 : date.getTime();
        };

        const formatDurationMs = (value) => {
          const ms = Math.max(0, Number(value) || 0);
          const totalSeconds = Math.floor(ms / 1000);
          const hours = Math.floor(totalSeconds / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;

          if (hours) return `${hours}h ${String(minutes).padStart(2, '0')}m`;
          if (minutes) return `${minutes}m ${String(seconds).padStart(2, '0')}s`;
          return `${seconds}s`;
        };

        const formatDuration = (startValue, endValue = Date.now()) => {
          const startMs = timestampToMs(startValue);
          const endMs = timestampToMs(endValue) || Date.now();
          if (!startMs) return '';
          return formatDurationMs(Math.max(0, endMs - startMs));
        };

        const formatRelative = (value) => {
          const timestamp = timestampToMs(value);
          if (!timestamp) return '';
          const diff = Math.max(0, Date.now() - timestamp);
          if (diff < 2000) return 'just now';
          if (diff < 60_000) return `${Math.floor(diff / 1000)}s ago`;
          if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
          if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
          return `${Math.floor(diff / 86_400_000)}d ago`;
        };

        const ensureLiveTicker = () => {
          if (liveTicker) return;
          liveTicker = window.setInterval(() => {
            renderOperationHealth();
          }, 1000);
        };

        const setConnectionState = (nextState, { mode = '', touchAt = 0 } = {}) => {
          connectionState = String(nextState || '').trim() || 'idle';
          if (mode) transportMode = mode;
          const contactMs = timestampToMs(touchAt);
          if (contactMs) lastContactAt = contactMs;
          renderOperationHealth();
        };

        const touchConnection = (mode = '', value = Date.now()) => {
          transportMode = mode || transportMode || 'stream';
          connectionState = 'live';
          lastContactAt = timestampToMs(value) || Date.now();
          renderOperationHealth();
        };

        const renderOperationHealth = () => {
          const liveStateEl = document.getElementById('backupOperationLiveState');
          const liveLabelEl = document.getElementById('backupOperationLiveLabel');
          const healthEl = document.getElementById('backupOperationHealth');
          const metaEl = document.getElementById('backupOperationMeta');
          if (!healthEl || !metaEl || !currentOperation) return;

          const normalizedStatus = String(currentOperation.status || 'running').toLowerCase();
          const startedAt = formatTimestamp(currentOperation.startedAt, 'Started');
          const updatedAt = formatTimestamp(currentOperation.updatedAt, 'Updated');
          const finishedAt = formatTimestamp(currentOperation.completedAt, 'Finished');
          const elapsed = currentOperation.startedAt
            ? formatDuration(
                currentOperation.startedAt,
                normalizedStatus === 'completed' || normalizedStatus === 'failed'
                  ? currentOperation.completedAt || Date.now()
                  : Date.now()
              )
            : '';
          const lastProgress = formatRelative(currentOperation.updatedAt);
          const lastPing = formatRelative(lastContactAt);
          const sincePingMs = lastContactAt ? Math.max(0, Date.now() - lastContactAt) : Infinity;
          const healthBits = [];
          const metaBits = [];
          let liveClass = 'backup-operation-live is-idle';
          let liveLabel = 'IDLE';

          if (normalizedStatus === 'completed') {
            liveClass = 'backup-operation-live is-done';
            liveLabel = 'DONE';
            if (currentOperation.completedAt) healthBits.push(`Finished ${formatRelative(currentOperation.completedAt)}`);
            if (elapsed) healthBits.push(`elapsed ${elapsed}`);
          } else if (normalizedStatus === 'failed') {
            liveClass = 'backup-operation-live is-failed';
            liveLabel = 'FAILED';
            healthBits.push('Operation stopped');
            if (elapsed) healthBits.push(`after ${elapsed}`);
          } else if (connectionState === 'connecting') {
            liveClass = 'backup-operation-live is-connecting';
            liveLabel = 'CONNECTING';
            healthBits.push('Opening live updates...');
            if (elapsed) healthBits.push(`elapsed ${elapsed}`);
          } else if (connectionState === 'reconnecting') {
            liveClass = 'backup-operation-live is-waiting';
            liveLabel = 'RECONNECTING';
            healthBits.push('Connection dropped, retrying...');
            if (lastPing) healthBits.push(`last ping ${lastPing}`);
            if (elapsed) healthBits.push(`elapsed ${elapsed}`);
          } else if (sincePingMs > 15000) {
            liveClass = 'backup-operation-live is-stale';
            liveLabel = 'STALLED';
            healthBits.push(`No server heartbeat for ${formatDurationMs(sincePingMs)}`);
            if (elapsed) healthBits.push(`elapsed ${elapsed}`);
          } else {
            liveClass = `backup-operation-live ${transportMode === 'poll' ? 'is-polling' : 'is-live'}`;
            liveLabel = 'LIVE';
            healthBits.push(transportMode === 'poll' ? 'Live via polling' : 'Live via stream');
            if (lastPing) healthBits.push(`last ping ${lastPing}`);
            if (lastProgress) healthBits.push(`last progress ${lastProgress}`);
            if (elapsed) healthBits.push(`elapsed ${elapsed}`);
          }

          if (startedAt) metaBits.push(startedAt);
          if (normalizedStatus === 'running' && updatedAt) metaBits.push(updatedAt);
          if ((normalizedStatus === 'completed' || normalizedStatus === 'failed') && finishedAt) metaBits.push(finishedAt);
          if (currentOperation.error) metaBits.push(currentOperation.error);

          if (liveStateEl) liveStateEl.className = liveClass;
          if (liveLabelEl) liveLabelEl.textContent = liveLabel;
          healthEl.textContent = healthBits.join(' · ');
          metaEl.textContent = metaBits.join(' · ');
        };

        const ensureCard = (operation = {}) => {
          let card = document.getElementById('backupOperationCard');
          if (card) return card;

          mount.innerHTML = `
            <section class="card shadow-sm mb-4 backup-operation-card" id="backupOperationCard" data-operation-id="${escapeHtml(operation.operationId || '')}" data-status="${escapeHtml(operation.status || 'running')}">
              <div class="card-body">
                <div class="backup-operation-head mb-3">
                  <div class="backup-operation-copy">
                    <div class="text-uppercase text-muted small" id="backupOperationEyebrow">${escapeHtml(operation.action === 'restore' ? 'Restore Progress' : 'Backup Progress')}</div>
                    <h2 class="h6 mb-1" id="backupOperationLabel">${escapeHtml(operation.label || 'Preparing backup operation')}</h2>
                    <div class="text-muted small" id="backupOperationMessage">${escapeHtml(operation.message || 'Waiting for server response...')}</div>
                  </div>
                  <div class="backup-operation-badges">
                    <span class="backup-operation-live is-connecting" id="backupOperationLiveState">
                      <span class="backup-operation-live__dot"></span>
                      <span id="backupOperationLiveLabel">CONNECTING</span>
                    </span>
                    <span class="badge text-bg-${statusClass(operation.status)}" id="backupOperationStatus">${escapeHtml(operation.status || 'running')}</span>
                  </div>
                </div>

                <div class="backup-operation-health small" id="backupOperationHealth">Opening live updates...</div>

                <div class="progress mb-2" role="progressbar" aria-label="Backup progress" aria-valuemin="0" aria-valuemax="100">
                  <div class="progress-bar bg-${statusClass(operation.status)}" id="backupOperationBar" style="width: ${Math.max(0, Math.min(100, Number(operation.progress || 0)))}%">
                    <span id="backupOperationPercent">${Math.max(0, Math.min(100, Number(operation.progress || 0)))}%</span>
                  </div>
                </div>

                <div class="small text-muted" id="backupOperationMeta"></div>
              </div>
            </section>
          `;

          return document.getElementById('backupOperationCard');
        };

        const setControlsDisabled = (disabled) => {
          [createForm, ...restoreForms].filter(Boolean).forEach((form) => {
            form.querySelectorAll('button[type="submit"]').forEach((button) => {
              button.disabled = Boolean(disabled);
            });
          });
        };

        const closeLiveUpdates = () => {
          if (stream) {
            stream.close();
            stream = null;
          }
          if (pollTimer) {
            window.clearTimeout(pollTimer);
            pollTimer = null;
          }
        };

        const scheduleReload = () => {
          if (reloadScheduled) return;
          reloadScheduled = true;
          window.setTimeout(() => window.location.reload(), 2500);
        };

        const updateOperationCard = (operation, { source = '', contactAt = 0, touch = true } = {}) => {
          if (!operation) return;
          currentOperation = operation;
          ensureLiveTicker();
          const card = ensureCard(operation);
          const eyebrowEl = document.getElementById('backupOperationEyebrow');
          const labelEl = document.getElementById('backupOperationLabel');
          const messageEl = document.getElementById('backupOperationMessage');
          const statusEl = document.getElementById('backupOperationStatus');
          const barEl = document.getElementById('backupOperationBar');
          const percentEl = document.getElementById('backupOperationPercent');
          const normalizedStatus = String(operation.status || 'running').toLowerCase();
          const progress = Math.max(0, Math.min(100, Number(operation.progress || 0)));
          const flavor = statusClass(normalizedStatus);

          activeOperationId = String(operation.operationId || '').trim();
          card.dataset.operationId = activeOperationId;
          card.dataset.status = normalizedStatus;
          if (eyebrowEl) eyebrowEl.textContent = operation.action === 'restore' ? 'Restore Progress' : 'Backup Progress';
          if (labelEl) labelEl.textContent = operation.label || 'Backup operation';
          if (messageEl) messageEl.textContent = operation.message || 'Queued';
          if (statusEl) {
            statusEl.textContent = normalizedStatus;
            statusEl.className = `badge text-bg-${flavor}`;
          }
          if (barEl) {
            barEl.className = `progress-bar bg-${flavor}`;
            barEl.style.width = `${progress}%`;
          }
          if (percentEl) percentEl.textContent = `${progress}%`;

          if (touch) {
            if (normalizedStatus === 'running') {
              touchConnection(source || transportMode || 'stream', contactAt || operation.updatedAt || Date.now());
            } else if (contactAt) {
              lastContactAt = timestampToMs(contactAt) || lastContactAt;
            }
          }

          if (normalizedStatus === 'completed' || normalizedStatus === 'failed') {
            connectionState = 'settled';
          }

          renderOperationHealth();
          setControlsDisabled(normalizedStatus === 'running');
          if (normalizedStatus === 'completed' && activeOperationId) {
            closeLiveUpdates();
            scheduleReload();
          }
          if (normalizedStatus === 'failed') {
            closeLiveUpdates();
          }
        };

        const pollOperation = async (operationId) => {
          if (!operationId) return;
          try {
            const response = await fetch(`/admin/backups/operations/${encodeURIComponent(operationId)}`, {
              headers: { Accept: 'application/json' },
              credentials: 'same-origin'
            });
            if (!response.ok) throw new Error('poll_failed');
            const payload = await response.json();
            if (!payload?.ok || !payload.operation) throw new Error('invalid_payload');
            updateOperationCard(payload.operation, {
              source: 'poll',
              contactAt: payload.serverTime || Date.now()
            });
            if (String(payload.operation.status || '').toLowerCase() === 'running') {
              pollTimer = window.setTimeout(() => pollOperation(operationId), 600);
            }
          } catch (_error) {
            setConnectionState('reconnecting', { mode: 'poll' });
            pollTimer = window.setTimeout(() => pollOperation(operationId), 1200);
          }
        };

        const subscribeToOperation = (operationId) => {
          if (!operationId) return;
          closeLiveUpdates();
          activeOperationId = operationId;
          setConnectionState('connecting', { mode: 'stream' });

          if (typeof window.EventSource !== 'function') {
            setConnectionState('reconnecting', { mode: 'poll' });
            pollOperation(operationId);
            return;
          }

          stream = new window.EventSource(`/admin/backups/operations/${encodeURIComponent(operationId)}/stream`);
          stream.onopen = () => {
            touchConnection('stream');
          };
          stream.onmessage = (event) => {
            try {
              const payload = JSON.parse(event.data || '{}');
              if (!payload?.ok || !payload.operation) return;
              updateOperationCard(payload.operation, {
                source: 'stream',
                contactAt: payload.serverTime || Date.now()
              });
            } catch (_error) {
              // ignore malformed events
            }
          };
          stream.onerror = () => {
            closeLiveUpdates();
            setConnectionState('reconnecting', { mode: 'poll' });
            pollOperation(operationId);
          };
        };

        const submitBackupForm = async (form, fallbackLabel) => {
          if (!form || typeof window.fetch !== 'function') {
            form?.submit?.();
            return;
          }

          closeLiveUpdates();
          activeOperationId = '';
          reloadScheduled = false;
          updateOperationCard({
            action: form.action.includes('/restore') ? 'restore' : 'create',
            label: fallbackLabel,
            status: 'running',
            progress: 0,
            message: 'Contacting server...',
            startedAt: new Date().toISOString(),
            operationId: ''
          }, { touch: false });
          setConnectionState('connecting', { mode: 'stream' });

          try {
            const formData = new window.FormData(form);
            const response = await fetch(form.action, {
              method: 'POST',
              headers: {
                Accept: 'application/json',
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: new URLSearchParams(formData).toString(),
              credentials: 'same-origin'
            });

            const payload = await response.json().catch(() => null);
            if (payload?.reason === 'already_running' && payload?.operation) {
              updateOperationCard(payload.operation, {
                source: 'stream',
                touch: false
              });
              subscribeToOperation(payload.operation.operationId);
              return;
            }
            if (!response.ok || !payload?.ok || !payload.operation) {
              throw new Error(payload?.reason || 'Request failed.');
            }

            updateOperationCard(payload.operation, {
              source: 'stream',
              touch: false
            });
            subscribeToOperation(payload.operation.operationId);
          } catch (error) {
            updateOperationCard({
              action: form.action.includes('/restore') ? 'restore' : 'create',
              label: fallbackLabel,
              status: 'failed',
              progress: 100,
              message: String(error?.message || error || 'Request failed.'),
              error: String(error?.message || error || 'Request failed.'),
              startedAt: new Date().toISOString(),
              completedAt: new Date().toISOString()
            }, { touch: false });
          }
        };

        if (createForm) {
          createForm.addEventListener('submit', (event) => {
            event.preventDefault();
            submitBackupForm(createForm, 'Creating backup');
          });
        }

        restoreForms.forEach((form) => {
          form.addEventListener('submit', (event) => {
            event.preventDefault();
            submitBackupForm(form, 'Restoring backup');
          });
        });

        const existingCard = document.getElementById('backupOperationCard');
        if (existingCard) {
          const existingStatus = String(existingCard.dataset.status || '').toLowerCase();
          const existingId = String(existingCard.dataset.operationId || '').trim();
          if (initialOperation) {
            updateOperationCard(initialOperation, { touch: false });
          }
          setControlsDisabled(existingStatus === 'running');
          if (existingStatus === 'running' && existingId) {
            subscribeToOperation(existingId);
          } else {
            renderOperationHealth();
          }
        }
      })();
    </script>
    <%- include('../../partials/footer') %>
  </body>
</html>
