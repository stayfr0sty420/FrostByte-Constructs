<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4 servers-page">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
        <div>
          <h1 class="h4 mb-1">Servers & Approvals</h1>
          <div class="text-muted small">
            Invite the bots to a server → approve it here → features unlock. You can approve even if some bots are missing.
          </div>
        </div>
        <div class="text-muted small">Total: <%= servers.length %></div>
      </div>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="card shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 servers-table">
              <thead>
                <tr>
                  <th>Server</th>
                  <th>Guild ID</th>
                  <th>Bots</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!servers.length) { %>
                  <tr>
                    <td colspan="5" class="text-muted py-4">
                      No servers found in the database yet. Add the bots to a server and refresh.
                    </td>
                  </tr>
                <% } %>

                <% servers.forEach(s => { %>
                  <% const allBots = s.presence.economy && s.presence.backup && s.presence.verification; %>
                  <tr>
                    <td class="server-cell" data-label="Server">
                      <div class="server-name"><%= s.name %></div>
                    </td>
                    <td class="server-id" data-label="Guild ID"><code><%= s.guildId %></code></td>
                    <td class="bots-cell" data-label="Bots">
                      <div class="bot-pills d-inline-flex align-items-center gap-1 flex-wrap">
                        <span class="badge <%= s.presence.economy ? 'text-bg-success' : 'text-bg-secondary' %>">E</span>
                        <span class="badge <%= s.presence.backup ? 'text-bg-success' : 'text-bg-secondary' %>">B</span>
                        <span class="badge <%= s.presence.verification ? 'text-bg-success' : 'text-bg-secondary' %>">V</span>
                      </div>
                      <% if (!allBots) { %>
                        <span class="text-muted small ms-2">(missing)</span>
                      <% } %>
                    </td>
                    <td class="status-cell" data-label="Status">
                      <% const badge = s.status === 'approved' ? 'success' : (s.status === 'rejected' ? 'danger' : 'warning'); %>
                      <div class="status-stack d-flex flex-column">
                        <div><span class="badge text-bg-<%= badge %>"><%= s.status %></span></div>
                        <% if (s.reviewedAt) { %>
                          <div class="status-meta text-muted small">
                            <%= new Date(s.reviewedAt).toISOString().slice(0, 19).replace('T', ' ') %>
                            <%= s.reviewedBy ? ` • ${s.reviewedBy}` : '' %>
                          </div>
                        <% } %>
                      </div>
                    </td>
                    <td class="text-end actions-cell" data-label="Actions">
                      <div class="action-group d-inline-flex gap-2 flex-wrap justify-content-end">
                        <form method="post" action="/admin/servers/select" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="guildId" value="<%= s.guildId %>" />
                          <button class="btn btn-outline-primary btn-sm" type="submit" <%= (s.status !== 'approved' || !allBots) ? 'disabled' : '' %>>
                            Manage
                          </button>
                        </form>

                        <% if (s.status !== 'approved') { %>
                          <form method="post" action="/admin/servers/approve/<%= s.guildId %>" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button class="btn btn-success btn-sm" type="submit">
                              Approve
                            </button>
                          </form>
                        <% } %>

                        <% if (s.status !== 'rejected') { %>
                          <form method="post" action="/admin/servers/reject/<%= s.guildId %>" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button
                              class="btn btn-outline-danger btn-sm"
                              type="submit"
                              data-confirm="Reject this server? Bots will stop working there."
                              data-confirm-title="Reject server?"
                              data-confirm-ok="Reject"
                              data-confirm-cancel="Cancel"
                            >
                              Reject
                            </button>
                          </form>
                        <% } %>

                        <form method="post" action="/admin/servers/delete/<%= s.guildId %>" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button
                            class="btn btn-outline-danger btn-sm btn-delete"
                            type="submit"
                            data-confirm="Delete this server and all related data? This cannot be undone."
                            data-confirm-title="Delete server?"
                            data-confirm-ok="Delete"
                            data-confirm-cancel="Cancel"
                          >
                            Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
