<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4 servers-page">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
        <div>
          <h1 class="h4 mb-1">Servers & Approvals</h1>
          <div class="text-muted small">
            Invite the bots to a server → approve it here → features unlock. You can approve even if some bots are missing.
          </div>
        </div>
        <div class="text-muted small">Total: <%= servers.length %></div>
      </div>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="card shadow-sm" data-csrf="<%= csrfToken %>">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 servers-table">
              <thead>
                <tr>
                  <th></th>
                  <th>Server</th>
                  <th>Guild ID</th>
                  <th>Bots</th>
                  <th>Application Date</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!servers.length) { %>
                  <tr>
                    <td colspan="6" class="text-muted py-4">
                      No servers found in the database yet. Add the bots to a server and refresh.
                    </td>
                  </tr>
                <% } %>

                <% servers.forEach(s => { %>
                  <% const selectUrl = `/admin/servers/select/${s.guildId}`; %>
                  <tr
                    class="server-row"
                    data-guild-select="<%= s.guildId %>"
                    data-guild-url="<%= selectUrl %>"
                    tabindex="0"
                    role="link"
                    aria-label="Open dashboard for <%= s.name %>"
                  >
                    <td class="server-icon-cell" data-label="Icon">
                      <a class="server-row-link server-row-link--icon" href="<%= selectUrl %>" aria-label="Open dashboard for <%= s.name %>">
                        <span class="server-icon" data-fallback="SV">
                        <% if (s.iconUrl) { %>
                          <img src="<%= s.iconUrl %>" alt="<%= s.name %> icon" loading="lazy" data-fallback-img />
                        <% } %>
                        <span class="server-icon-fallback"><%= (s.name || 'S').slice(0, 2).toUpperCase() %></span>
                        </span>
                      </a>
                    </td>
                    <td class="server-cell" data-label="Server">
                      <a class="server-row-link server-row-link--name" href="<%= selectUrl %>">
                        <span class="server-name"><%= s.name %></span>
                      </a>
                    </td>
                    <td class="server-id" data-label="Guild ID"><code><%= s.guildId %></code></td>
                    <td class="bots-cell" data-label="Bots">
                      <div class="bot-icon-row d-inline-flex align-items-center gap-2 flex-wrap">
                        <% (s.bots || []).forEach(b => { %>
                          <span class="bot-icon-sm <%= b.status %><%= b.key === 'verification' ? ' bot-icon-sm--website' : '' %>" title="<%= b.name %>: <%= b.status %>">
                            <img src="<%= b.icon %>" alt="<%= b.name %> logo" loading="lazy" />
                            <span class="bot-status-dot <%= b.status %>"></span>
                          </span>
                        <% }) %>
                      </div>
                    </td>
                    <td class="status-cell" data-label="Application Date">
                      <span class="text-muted small"><%= formatDate(s.createdAt) || '—' %></span>
                    </td>
                    <td class="text-end actions-cell" data-label="Actions">
                      <div class="action-group d-inline-flex gap-2 flex-wrap justify-content-end">
                        <a class="btn btn-outline-primary btn-sm" href="/admin/servers/<%= s.guildId %>/approvals">
                          Manage Approvals
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <script>
      (() => {
        const rows = document.querySelectorAll('.servers-table .server-row[data-guild-select]');
        if (!rows.length) return;
        rows.forEach((row) => {
          row.addEventListener('click', (event) => {
            if (event.target.closest('a,button,form,input,select,textarea,label')) return;
            const url = row.getAttribute('data-guild-url');
            if (!url) return;
            window.location.href = url;
          });
          row.addEventListener('keydown', (event) => {
            if (event.target.closest('a,button,form,input,select,textarea,label')) return;
            if (event.key !== 'Enter' && event.key !== ' ') return;
            event.preventDefault();
            const url = row.getAttribute('data-guild-url');
            if (!url) return;
            window.location.href = url;
          });
        });
      })();
    </script>
    <%- include('../../partials/footer') %>
  </body>
</html>
