<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h4 m-0">IP Logs</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/verification/settings">Back</a>
      </div>

      <div class="alert alert-warning ip-logs-alert">
        Admin-only: IP logs may contain personal data. Keep this private and follow your local privacy laws.
      </div>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="input-group input-group-sm log-search">
          <span class="input-group-text">Search</span>
          <input class="form-control" type="search" placeholder="Search IP logs..." data-log-search />
        </div>
        <div class="text-muted small" data-log-count></div>
      </div>

      <div class="table-responsive ip-logs-table-wrap">
        <table class="table table-sm align-middle ip-logs-table">
          <thead>
            <tr>
              <th>Observed IP</th>
              <th>Username</th>
              <th>Email</th>
              <th>GPS Geo</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr data-log-empty style="<%= logs.length ? 'display:none;' : '' %>">
              <td colspan="5" class="text-muted small">No logs yet.</td>
            </tr>
            <% logs.forEach(l => { %>
              <%
                const searchText = [
                  l.ip,
                  l.username,
                  l.discordId,
                  l.email,
                  l.geo?.lat,
                  l.geo?.lon
                ]
                  .map((v) => String(v || '').trim())
                  .filter(Boolean)
                  .join(' ')
                  .toLowerCase();
              %>
              <tr class="ip-log-row" data-log-row data-search="<%= searchText %>">
                <td>
                  <div><code><%= l.ip %></code></div>
                  <div class="text-muted small"><%= formatDate(l.lastSeenAt) || '' %></div>
                </td>
                <td>
                  <div class="fw-semibold"><%= l.username || 'Unknown' %></div>
                  <div class="text-muted small"><%= l.discordId ? l.discordId : '—' %></div>
                </td>
                <td class="text-muted small"><%= l.email || '—' %></td>
                <td class="text-muted small">
                  <% if (l.geo && l.geo.lat !== null && l.geo.lon !== null) { %>
                    <a class="link-danger" href="https://www.google.com/maps?q=<%= encodeURIComponent(String(l.geo.lat) + ',' + String(l.geo.lon)) %>" target="_blank" rel="noreferrer">Map Location</a>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td class="text-end">
                  <form method="post" action="/admin/verification/iplogs/delete/<%= l._id %>" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button
                      class="btn btn-outline-danger btn-sm icon-btn"
                      type="submit"
                      data-confirm="Delete this IP log entry? This will remove it from the database."
                      data-confirm-title="Delete IP log?"
                      data-confirm-ok="Delete"
                      data-confirm-cancel="Cancel"
                    >
                      🗑️
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
