<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page economy-player-profile-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <% const safeInventoryByRarity = inventoryByRarity && typeof inventoryByRarity === 'object' ? inventoryByRarity : {}; %>
      <% const safeInventory = Array.isArray(inventory) ? inventory : []; %>
      <% const safeTopInventory = Array.isArray(topInventory) ? topInventory : []; %>
      <% const safeTopPvpItems = Array.isArray(topPvpItems) ? topPvpItems : []; %>
      <% const safeTransactions = Array.isArray(transactions) ? transactions : []; %>
      <% const loadout = Array.isArray(snapshot?.loadout) ? snapshot.loadout.filter(entry => entry?.item) : []; %>
      <% const effectiveStats = snapshot?.effectiveStats || {}; %>
      <% const bonusStats = snapshot?.bonusStats || {}; %>
      <% const totalInventoryItems = safeInventory.reduce((sum, entry) => sum + Math.max(0, Number(entry.quantity) || 0), 0); %>
      <% const spouseLabel = spouseUser?.username || spouseUser?.discordId || user.marriedTo || ''; %>
      <% const fmtFull = (value) => Math.floor(Number(value || 0)).toLocaleString('en-US'); %>
      <% const fmtCompact = (value, threshold = 1000) => formatCompactNumber(value, { threshold }); %>
      <% const analyticsQuery = analyticsScope === 'global' ? '?scope=global' : ''; %>

      <section class="dashboard-hero mb-4">
        <div class="dashboard-hero__copy">
          <div class="hero-eyebrow">RoBot Player Profile</div>
          <h1 class="hero-title mb-2"><%= user.username || user.discordId %></h1>
          <p class="hero-text mb-0">
            <code><%= user.discordId %></code>
            <% if (user.economyBan?.active) { %>
              • <span class="text-danger">Economy banned</span>
            <% } %>
          </p>
        </div>
        <div class="dashboard-hero__actions">
          <a href="/admin/economy/analytics<%= analyticsQuery %>" class="btn btn-outline-secondary btn-sm">Back to Analytics</a>
          <a href="/admin/economy/users/<%= user.discordId %>" class="btn btn-outline-light btn-sm">Open Editor</a>
        </div>
      </section>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Wallet</div>
              <div class="display-6" title="<%= fmtFull(user.balance) %>"><%= fmtCompact(user.balance) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Bank</div>
              <div class="display-6" title="<%= fmtFull(user.bank) %>"><%= fmtCompact(user.bank) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Level</div>
              <div class="display-6" title="<%= fmtFull(user.level) %>"><%= fmtCompact(user.level) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Gear Score</div>
              <div class="display-6" title="<%= fmtFull(snapshot?.gearScore) %>"><%= fmtCompact(snapshot?.gearScore) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">PvP Rating</div>
              <div class="display-6" title="<%= fmtFull(user.pvpRating) %>"><%= fmtCompact(user.pvpRating) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-2">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Followers</div>
              <div class="display-6" title="<%= fmtFull(user.followers?.length || 0) %>"><%= fmtCompact(user.followers?.length || 0) %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12 col-xl-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h2 class="h5 mb-3">Profile Summary</h2>
              <div class="player-profile-banner" <% if (wallpaperItem?.wallpaperUrl) { %>style="--player-wallpaper:url('<%= wallpaperItem.wallpaperUrl %>');"<% } %>>
                <div class="player-profile-banner__glass"></div>
                <div class="player-profile-banner__content">
                  <div class="player-profile-copy">
                    <div class="player-profile-label">Title</div>
                    <div class="player-profile-value"><%= user.profileTitle || 'default' %></div>
                    <div class="player-profile-label mt-3">Bio</div>
                    <div class="player-profile-value player-profile-bio"><%= user.profileBio || 'default' %></div>
                  </div>
                  <div class="player-profile-badge-strip">
                    <% if (safeTopPvpItems.length) { %>
                      <% safeTopPvpItems.forEach((entry, index) => { const rarityClass = String(entry.item?.rarity || 'common').toLowerCase(); %>
                        <% const badgeSrc = entry.item?.imageUrl || entry.item?.emojiUrl || ''; %>
                        <div
                          class="player-profile-badge player-profile-badge--<%= rarityClass %> position-relative"
                          title="<%= entry.item?.name || entry.itemId %> • <%= entry.item?.rarity || 'unknown' %><% if (entry.inventory?.refinement || entry.refinement) { %> • +<%= fmtCompact(entry.inventory?.refinement || entry.refinement, 1) %><% } %>"
                        >
                          <% if (badgeSrc) { %>
                            <img src="<%= badgeSrc %>" alt="<%= entry.item?.name || entry.itemId %>" loading="lazy" />
                          <% } else { %>
                            <span class="player-profile-badge__fallback"><%= entry.item?.emojiText || `#${index + 1}` %></span>
                          <% } %>
                          <% if (Number(entry.inventory?.refinement || entry.refinement || 0) > 0) { %>
                            <span class="badge text-bg-dark position-absolute bottom-0 end-0 mb-1 me-1">+<%= fmtCompact(entry.inventory?.refinement || entry.refinement, 1) %></span>
                          <% } %>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <div class="player-profile-badge player-profile-badge--empty">No PvP gear highlights yet.</div>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="row g-3 mt-1">
                <div class="col-12 col-lg-6">
                  <div class="player-profile-meta-card">
                    <div class="player-profile-meta-row">
                      <span>Wallpaper</span>
                      <strong><%= wallpaperItem?.name || user.profileWallpaper || 'default' %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Followers</span>
                      <strong><%= fmtCompact(user.followers?.length || 0) %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Following</span>
                      <strong><%= fmtCompact(user.following?.length || 0) %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Shared Bank</span>
                      <strong><%= user.sharedBankEnabled ? 'Enabled' : 'Disabled' %></strong>
                    </div>
                  </div>
                </div>
                <div class="col-12 col-lg-6">
                  <div class="player-profile-meta-card">
                    <div class="player-profile-meta-row">
                      <span>Spouse</span>
                      <strong><%= spouseLabel || 'Single' %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Marriage Ring</span>
                      <strong><%= snapshot?.ring?.name || user.marriageRingItemId || 'None' %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Ring Rarity</span>
                      <strong><%= snapshot?.ring?.rarity || '—' %></strong>
                    </div>
                    <div class="player-profile-meta-row">
                      <span>Married Since</span>
                      <strong><%= user.marriedSince ? formatDate(user.marriedSince) : '—' %></strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h2 class="h5 mb-3">Combat Stats</h2>
              <div class="row g-3">
                <% [
                  ['STR', effectiveStats.str, bonusStats.str],
                  ['AGI', effectiveStats.agi, bonusStats.agi],
                  ['VIT', effectiveStats.vit, bonusStats.vit],
                  ['LUCK', effectiveStats.luck, bonusStats.luck],
                  ['CRIT', effectiveStats.crit, bonusStats.crit]
                ].forEach(([label, value, bonus]) => { %>
                  <div class="col-6 col-md-4 col-xl-2">
                    <div class="player-stat-tile">
                      <div class="player-stat-tile__label"><%= label %></div>
                      <div class="player-stat-tile__value" title="<%= fmtFull(value) %>"><%= fmtCompact(value) %></div>
                      <div class="player-stat-tile__bonus"><%= Number(bonus || 0) > 0 ? `+${fmtCompact(bonus)} gear` : 'No bonus' %></div>
                    </div>
                  </div>
                <% }) %>
                <div class="col-6 col-md-4 col-xl-2">
                  <div class="player-stat-tile">
                    <div class="player-stat-tile__label">Max HP</div>
                    <div class="player-stat-tile__value" title="<%= fmtFull(snapshot?.maxHp) %>"><%= fmtCompact(snapshot?.maxHp) %></div>
                    <div class="player-stat-tile__bonus">Level-scaled</div>
                  </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                  <div class="player-stat-tile">
                    <div class="player-stat-tile__label">Energy</div>
                    <div class="player-stat-tile__value"><%= fmtCompact(user.energy) %>/<%= fmtCompact(user.energyMax) %></div>
                    <div class="player-stat-tile__bonus">Live pool</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h2 class="h5 mb-3">Equipped & Featured Items</h2>
              <div class="player-loadout-grid">
                <% if (!loadout.length && !snapshot?.ring) { %>
                  <div class="text-muted">No equipped items or marriage ring bonuses recorded.</div>
                <% } %>
                <% loadout.forEach(entry => { const rarityClass = String(entry.item?.rarity || 'common').toLowerCase(); %>
                  <div class="player-loadout-card">
                    <div class="player-loadout-card__slot"><%= entry.slot %></div>
                    <div class="player-loadout-card__name"><%= entry.item?.name || entry.itemId %></div>
                    <div class="player-loadout-card__meta">
                      <span class="rarity-pill rarity-pill--<%= rarityClass %>"><%= entry.item?.rarity || 'unknown' %></span>
                      <span>+<%= fmtCompact(entry.inventory?.refinement || 0) %></span>
                    </div>
                  </div>
                <% }) %>
                <% if (snapshot?.ring) { %>
                  <div class="player-loadout-card">
                    <div class="player-loadout-card__slot">Marriage Ring</div>
                    <div class="player-loadout-card__name"><%= snapshot.ring.name %></div>
                    <div class="player-loadout-card__meta">
                      <span class="badge text-bg-info text-uppercase"><%= snapshot.ring.rarity || 'ring' %></span>
                      <span>Shared bonus active</span>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <h2 class="h5 mb-0">Inventory Highlights</h2>
                <div class="text-muted small">Tracked items: <%= fmtCompact(totalInventoryItems) %></div>
              </div>

              <div class="row g-3 mb-4">
                <% ['common','rare','epic','pristine','transcendent','primordial'].forEach(rarity => { %>
                  <div class="col-6 col-md-4 col-xl-2">
                    <div class="player-rarity-card rarity-card rarity-card--<%= rarity %>">
                      <div class="text-uppercase text-muted small"><%= rarity %></div>
                      <div class="fs-5" title="<%= fmtFull(safeInventoryByRarity[rarity] || 0) %>"><%= fmtCompact(safeInventoryByRarity[rarity] || 0) %></div>
                    </div>
                  </div>
                <% }) %>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 analytics-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Rarity</th>
                      <th class="text-end">Qty</th>
                      <th class="text-end">Refine</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!safeTopInventory.length) { %>
                      <tr>
                        <td colspan="4" class="text-muted py-3">Inventory is empty.</td>
                      </tr>
                    <% } %>
                    <% safeTopInventory.forEach(entry => { const rarityClass = String(entry.item?.rarity || 'common').toLowerCase(); %>
                      <tr>
                        <td data-label="Item">
                          <div class="fw-semibold"><%= entry.item?.name || entry.itemId %></div>
                          <div class="text-muted small"><code><%= entry.itemId %></code></div>
                        </td>
                        <td data-label="Rarity"><span class="rarity-pill rarity-pill--<%= rarityClass %>"><%= entry.item?.rarity || 'unknown' %></span></td>
                        <td class="text-end" data-label="Qty" title="<%= fmtFull(entry.quantity) %>"><%= fmtCompact(entry.quantity) %></td>
                        <td class="text-end" data-label="Refine">+<%= fmtCompact(entry.refinement) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5 mb-3">Recent Economy Activity</h2>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 analytics-table">
                  <thead>
                    <tr>
                      <% if (analyticsScope === 'global') { %><th>Server</th><% } %>
                      <th>Type</th>
                      <th class="text-end">Amount</th>
                      <th class="text-end">Wallet</th>
                      <th class="text-end">Bank</th>
                      <th>When</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!safeTransactions.length) { %>
                      <tr>
                        <td colspan="<%= analyticsScope === 'global' ? 6 : 5 %>" class="text-muted py-3">No recent economy activity logged.</td>
                      </tr>
                    <% } %>
                    <% safeTransactions.forEach(tx => { %>
                      <tr>
                        <% if (analyticsScope === 'global') { %>
                          <td data-label="Server"><%= tx.guildName || tx.guildId || 'Unknown' %></td>
                        <% } %>
                        <td data-label="Type"><code><%= tx.type %></code></td>
                        <td class="text-end" data-label="Amount" title="<%= fmtFull(tx.amount) %>"><%= formatTransactionNumber(tx.amount) %></td>
                        <td class="text-end" data-label="Wallet" title="<%= fmtFull(tx.balanceAfter) %>"><%= formatTransactionNumber(tx.balanceAfter) %></td>
                        <td class="text-end" data-label="Bank" title="<%= fmtFull(tx.bankAfter) %>"><%= formatTransactionNumber(tx.bankAfter) %></td>
                        <td data-label="When" class="text-muted small"><%= tx.createdAt ? formatDate(tx.createdAt) : '—' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-4">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h2 class="h5 mb-3">Player Flags</h2>
              <div class="player-profile-meta-card">
                <div class="player-profile-meta-row">
                  <span>Status</span>
                  <strong><%= user.economyBan?.active ? 'Banned' : 'Active' %></strong>
                </div>
                <div class="player-profile-meta-row">
                  <span>PvP Record</span>
                  <strong><%= fmtCompact(user.pvpWins) %>W / <%= fmtCompact(user.pvpLosses) %>L</strong>
                </div>
                <div class="player-profile-meta-row">
                  <span>Bank Capacity</span>
                  <strong title="<%= fmtFull(user.bankMax) %>"><%= fmtCompact(user.bankMax) %></strong>
                </div>
                <div class="player-profile-meta-row">
                  <span>Stat Points</span>
                  <strong title="<%= fmtFull(user.statPoints) %>"><%= fmtCompact(user.statPoints) %></strong>
                </div>
                <div class="player-profile-meta-row">
                  <span>EXP</span>
                  <strong title="<%= fmtFull(user.exp) %>"><%= fmtCompact(user.exp) %></strong>
                </div>
                <div class="player-profile-meta-row">
                  <span>Updated</span>
                  <strong><%= user.updatedAt ? formatDate(user.updatedAt) : '—' %></strong>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5 mb-3">Quick Actions</h2>
              <div class="d-grid gap-2">
                <a class="btn btn-outline-light" href="/admin/economy/users/<%= user.discordId %>">Open Full Editor</a>
                <a class="btn btn-outline-secondary" href="/admin/economy/users?q=<%= encodeURIComponent(user.discordId) %>">Find in Users List</a>
                <a class="btn btn-outline-secondary" href="/admin/economy/analytics<%= analyticsQuery %>">Back to Analytics</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
