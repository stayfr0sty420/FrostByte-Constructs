<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h4 m-0">Pending Verifications</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/verification/settings">Back</a>
      </div>

      <% if (!pending.length) { %>
        <div class="alert alert-success">No pending verifications.</div>
      <% } %>

      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead>
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Email</th>
              <th>IP</th>
              <th>Geo</th>
              <th>IP Geo</th>
              <th>Risk</th>
              <th>Created</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% pending.forEach(p => { %>
              <tr>
                <td><code><%= p.verificationId %></code></td>
                <td>
                  <div class="fw-semibold"><%= p.username || '(unknown)' %></div>
                  <div class="text-muted small"><code><%= p.discordId %></code></div>
                </td>
                <td class="text-muted small"><%= p.email || '' %></td>
                <td class="text-muted small">
                  <div><code><%= p.publicIp || p.ip %></code></div>
                  <% if (p.observedIp) { %>
                    <div class="text-white-50">Observed: <code><%= p.observedIp %></code></div>
                  <% } %>
                </td>
                <td class="text-muted small">
                  <% if (p.geo && p.geo.lat !== null && p.geo.lon !== null) { %>
                    <code><%= p.geo.lat %>, <%= p.geo.lon %></code>
                    <% if (p.geo.accuracy !== null) { %>
                      <span class="text-muted">±<%= Math.round(p.geo.accuracy) %>m</span>
                    <% } %>
                    <div>
                      <a class="link-danger" href="https://www.google.com/maps?q=<%= encodeURIComponent(String(p.geo.lat) + ',' + String(p.geo.lon)) %>" target="_blank" rel="noreferrer">Map</a>
                    </div>
                  <% } %>
                </td>
                <td class="text-muted small">
                  <% if (p.ipGeo && (p.ipGeo.city || p.ipGeo.region || p.ipGeo.country || (p.ipGeo.lat !== null && p.ipGeo.lon !== null))) { %>
                    <div><%= [p.ipGeo.city, p.ipGeo.region, p.ipGeo.country].filter(Boolean).join(', ') %></div>
                    <% if (p.ipGeo.timezone) { %>
                      <div class="text-white-50"><%= p.ipGeo.timezone %></div>
                    <% } %>
                    <% if (p.ipGeo.lat !== null && p.ipGeo.lon !== null) { %>
                      <div>
                        <a class="link-danger" href="https://www.google.com/maps?q=<%= encodeURIComponent(String(p.ipGeo.lat) + ',' + String(p.ipGeo.lon)) %>" target="_blank" rel="noreferrer">Map</a>
                      </div>
                    <% } %>
                  <% } %>
                </td>
                <td><%= p.riskScore %></td>
                <td class="text-muted small"><%= p.createdAt.toISOString() %></td>
                <td class="text-end">
                  <form method="post" action="/admin/verification/approve/<%= p.verificationId %>" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn btn-outline-success btn-sm" type="submit">Approve</button>
                  </form>
                  <form method="post" action="/admin/verification/deny/<%= p.verificationId %>" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn btn-outline-danger btn-sm" type="submit">Deny</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
