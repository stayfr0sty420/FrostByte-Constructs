<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page economy-items-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <section class="economy-items-hero mb-4">
        <div>
          <div class="hero-eyebrow">RoBot Item Management</div>
          <h1 class="hero-title mb-2">Items</h1>
          <p class="hero-text mb-0">Create new catalog entries, upload a media image for emoji sync, and manage the full shared item catalog from one place.</p>
        </div>
        <div class="text-muted small">Loaded <strong><%= Number(items.length || 0).toLocaleString('en-US') %></strong> items</div>
      </section>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <% const fmtFull = (value) => Math.floor(Number(value || 0)).toLocaleString('en-US'); %>
      <% const fmtCompact = (value, threshold = 1000) => formatCompactNumber(value, { threshold }); %>
      <% const editing = editingItem || null; %>
      <% const editingStats = editing?.stats || {}; %>
      <% const editingEffects = editing?.effects || {}; %>
      <% const editingPreview = editing?.imageUrl || editing?.wallpaperUrl || editing?.emojiUrl || ''; %>
      <% const editingPreviewFallback = editing?.emojiUrl || editing?.wallpaperUrl || ''; %>

      <div class="row g-4">
        <div class="col-12 col-xl-8">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <div>
                  <h2 class="h5 mb-1"><%= editing ? `Edit Item • ${editing.itemId}` : 'Create Item' %></h2>
                  <div class="text-muted small">
                    Leave Item ID blank and RoBot will generate a clean 12-character uppercase ID.
                    Existing item IDs now update the matching item, and the Edit button below will load the item into this form.
                  </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <% if (editing) { %>
                    <a class="btn btn-outline-light btn-sm" href="/admin/economy/items">Clear Edit</a>
                  <% } %>
                  <span class="badge text-bg-secondary">Catalog-wide</span>
                </div>
              </div>

              <form method="post" action="/admin/economy/items" class="row g-3 economy-item-form" data-item-editor>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="imageUploadData" value="" data-item-image-data />
                <input type="hidden" name="editingItemId" value="<%= editing?.itemId || '' %>" />

                <div class="col-12 col-lg-7">
                  <label class="form-label">Item ID</label>
                  <div class="input-group">
                    <input
                      class="form-control item-id-input"
                      name="itemId"
                      placeholder="Leave blank for auto ID or paste an existing ID to update"
                      value="<%= editing?.itemId || '' %>"
                      data-item-id-input
                    />
                    <button class="btn btn-outline-secondary" type="button" data-item-id-regenerate>Generate</button>
                  </div>
                  <div class="form-text">
                    <% if (editing) { %>
                      You can keep the current ID or generate a clean alphanumeric one. Saving will remap linked inventories, loadouts, wallpaper links, marriage rings, shop listings, and gacha references automatically.
                    <% } else { %>
                      Example: <code class="item-id-code"><%= generatedItemId %></code> • entering an existing Item ID will update that item.
                    <% } %>
                  </div>
                </div>
                <div class="col-12 col-lg-3">
                  <label class="form-label">Name</label>
                  <input class="form-control" name="name" placeholder="Arcblade" value="<%= editing?.name || '' %>" required />
                </div>
                <div class="col-12 col-lg-2">
                  <label class="form-label">Type</label>
                  <select class="form-select" name="type" required>
                    <% itemTypes.forEach(type => { %>
                      <option value="<%= type %>" <%= editing?.type === type ? 'selected' : '' %>><%= type %></option>
                    <% }) %>
                  </select>
                </div>

                <div class="col-12">
                  <label class="form-label">Description</label>
                  <textarea class="form-control" name="description" rows="2" placeholder="Short item description"><%= editing?.description || '' %></textarea>
                </div>

                <div class="col-12 col-lg-4">
                  <label class="form-label">Item Picture</label>
                  <input class="form-control" type="file" accept="image/*" data-item-image-input />
                  <div class="form-text">Uploading a picture also syncs or reuses a Discord emoji for shop and inventory displays.</div>
                </div>
                <div class="col-12 col-lg-4">
                  <label class="form-label">Image URL</label>
                  <input class="form-control" name="imageUrl" placeholder="Optional remote image URL" value="<%= editing?.imageUrl || '' %>" />
                </div>
                <div class="col-12 col-lg-4">
                  <label class="form-label">Wallpaper URL</label>
                  <input class="form-control" name="wallpaperUrl" placeholder="Optional wallpaper URL" value="<%= editing?.wallpaperUrl || '' %>" />
                </div>

                <div class="col-12">
                  <div class="economy-item-upload-card">
                    <div
                      class="economy-item-upload-card__preview"
                      data-item-image-preview
                      data-current-src="<%= editingPreview %>"
                      data-current-fallback-src="<%= editingPreviewFallback %>"
                    >
                      <% if (editingPreview) { %>
                        <img
                          src="<%= editingPreview %>"
                          alt="Item preview"
                          data-fallback-src="<%= editingPreviewFallback && editingPreviewFallback !== editingPreview ? editingPreviewFallback : '' %>"
                        />
                      <% } else { %>
                        <span>No picture selected</span>
                      <% } %>
                    </div>
                    <div class="economy-item-upload-card__copy">
                      <div class="fw-semibold">Emoji Sync Preview</div>
                      <div class="text-muted small">
                        RoBot will resize the item image, store the asset, and reuse an existing matching emoji when the same picture was already uploaded before.
                      </div>
                    </div>
                  </div>
                </div>

                <div class="col-6 col-md-3">
                  <label class="form-label">Rarity</label>
                  <select class="form-select" name="rarity" required>
                    <% rarities.forEach(rarity => { const meta = rarityMeta[rarity] || null; %>
                      <option value="<%= rarity %>" <%= editing?.rarity === rarity ? 'selected' : '' %>><%= meta?.label || rarity %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-6 col-md-3">
                  <label class="form-label">Price</label>
                  <input class="form-control" name="price" type="number" min="0" value="<%= editing?.price ?? 0 %>" />
                </div>
                <div class="col-6 col-md-3">
                  <label class="form-label">Item Score</label>
                  <input class="form-control" name="itemScore" type="number" min="0" value="<%= editing?.itemScore ?? 0 %>" />
                </div>
                <div class="col-6 col-md-3">
                  <label class="form-label">Box Key</label>
                  <input class="form-control" name="boxKey" placeholder="Optional" value="<%= editing?.boxKey || '' %>" />
                </div>

                <div class="col-12">
                  <label class="form-label">Tags</label>
                  <input class="form-control" name="tags" placeholder="ring, wallpaper, gacha_box, refine_crystal" value="<%= Array.isArray(editing?.tags) ? editing.tags.join(', ') : '' %>" />
                </div>

                <div class="col-6 col-lg-2">
                  <label class="form-label">STR</label>
                  <input class="form-control" name="statsStr" type="number" value="<%= editingStats.str ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-2">
                  <label class="form-label">AGI</label>
                  <input class="form-control" name="statsAgi" type="number" value="<%= editingStats.agi ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-2">
                  <label class="form-label">VIT</label>
                  <input class="form-control" name="statsVit" type="number" value="<%= editingStats.vit ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-2">
                  <label class="form-label">LUCK</label>
                  <input class="form-control" name="statsLuck" type="number" value="<%= editingStats.luck ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-2">
                  <label class="form-label">CRIT</label>
                  <input class="form-control" name="statsCrit" type="number" value="<%= editingStats.crit ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-2">
                  <label class="form-label">Effect Coins</label>
                  <input class="form-control" name="effectCoins" type="number" value="<%= editingEffects.coins ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-4">
                  <label class="form-label">Effect Energy</label>
                  <input class="form-control" name="effectEnergy" type="number" value="<%= editingEffects.energy ?? 0 %>" />
                </div>
                <div class="col-6 col-lg-4">
                  <label class="form-label">Effect EXP</label>
                  <input class="form-control" name="effectExp" type="number" value="<%= editingEffects.exp ?? 0 %>" />
                </div>

                <div class="col-12 d-flex flex-wrap gap-3">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="sellable" value="1" <%= editing ? (editing.sellable ? 'checked' : '') : 'checked' %> />
                    <label class="form-check-label">Sellable</label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="consumable" value="1" <%= editing?.consumable ? 'checked' : '' %> />
                    <label class="form-check-label">Consumable</label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="stackable" value="1" <%= editing ? (editing.stackable ? 'checked' : '') : 'checked' %> />
                    <label class="form-check-label">Stackable</label>
                  </div>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2">
                  <% if (editing) { %>
                    <a class="btn btn-outline-light" href="/admin/economy/items">Cancel</a>
                  <% } %>
                  <button class="btn btn-primary" type="submit"><%= editing ? 'Save Changes' : 'Save Item' %></button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-4">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
                <h2 class="h5 mb-0">CSV Uploader</h2>
                <a class="btn btn-outline-secondary btn-sm" href="/admin/economy/items/export">Export Backup</a>
              </div>
              <form method="post" action="/admin/economy/items/import" class="row g-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="col-12">
                  <label class="form-label">CSV Content</label>
                  <textarea class="form-control" name="csv" rows="11" placeholder="Paste CSV rows here with a header row."></textarea>
                  <div class="form-text">Supported headers are the same as the export file.</div>
                </div>
                <div class="col-12">
                  <div class="form-text">Existing item IDs are skipped automatically during CSV import. Imports are create-only.</div>
                </div>
                <div class="col-12 d-flex justify-content-end">
                  <button class="btn btn-outline-primary" type="submit">Import CSV</button>
                </div>
              </form>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5 mb-3">Find Items</h2>
              <form method="get" action="/admin/economy/items" class="row g-2">
                <div class="col-12 col-md">
                  <input class="form-control" name="q" value="<%= q || '' %>" placeholder="Search by ID, name, type, rarity, tag" />
                </div>
                <div class="col-12 col-md-auto d-grid">
                  <button class="btn btn-outline-light" type="submit">Search</button>
                </div>
              </form>
              <div class="form-text mt-2">Legacy rarities like <code>legendary</code> are normalized into the new rarity list automatically.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mt-4">
        <div class="card-body">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <h2 class="h5 mb-0">Item Database</h2>
            <div class="text-muted small">Latest <%= items.length %> result(s)</div>
          </div>
          <div class="table-responsive economy-items-table-wrap">
            <table class="table table-sm align-middle economy-items-table">
              <thead>
                <tr>
                  <th>Media</th>
                  <th>Item</th>
                  <th>Rarity</th>
                  <th class="text-end">Price</th>
                  <th class="text-end">Score</th>
                  <th>Flags</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!items.length) { %>
                  <tr>
                    <td colspan="7" class="text-muted py-4">No items matched this query.</td>
                  </tr>
                <% } %>
                <% items.forEach(it => { const meta = rarityMeta[it.rarity] || rarityMeta.common; %>
                  <tr>
                    <td data-label="Media">
                      <div class="item-media-thumb">
                        <% if (it.imageUrl || it.emojiUrl) { const primarySrc = it.imageUrl || it.emojiUrl; const fallbackSrc = it.emojiUrl && it.emojiUrl !== primarySrc ? it.emojiUrl : ''; %>
                          <img src="<%= primarySrc %>" alt="<%= it.name %>" loading="lazy" data-fallback-src="<%= fallbackSrc %>" />
                        <% } else { %>
                          <span><%= it.emojiText || 'IMG' %></span>
                        <% } %>
                      </div>
                    </td>
                    <td data-label="Item">
                      <div class="fw-semibold"><%= it.name %></div>
                      <div class="text-muted small"><code class="item-id-code"><%= it.itemId %></code> • <%= it.type %></div>
                    </td>
                    <td data-label="Rarity">
                      <span class="rarity-pill rarity-pill--<%= meta.key %>" title="<%= meta.label %>"><%= meta.label %></span>
                    </td>
                    <td data-label="Price" class="text-end" title="<%= fmtFull(it.price) %>"><%= fmtCompact(it.price) %></td>
                    <td data-label="Score" class="text-end" title="<%= fmtFull(it.itemScore) %>"><%= fmtCompact(it.itemScore) %></td>
                    <td data-label="Flags" class="small">
                      <%= it.sellable ? 'Sellable' : 'No Sell' %> •
                      <%= it.consumable ? 'Consumable' : 'Static' %> •
                      <%= it.stackable ? 'Stackable' : 'Unique' %>
                    </td>
                    <td data-label="Actions" class="text-end">
                      <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                        <a class="btn btn-outline-light btn-sm" href="/admin/economy/items?edit=<%= encodeURIComponent(it.itemId) %>">Edit</a>
                        <form method="post" action="/admin/economy/items/remove-global" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="itemId" value="<%= it.itemId %>" />
                          <button
                            class="btn btn-outline-warning btn-sm"
                            type="submit"
                            data-confirm="Remove this item from all player inventories and loadouts?"
                            data-confirm-title="Remove item globally?"
                            data-confirm-ok="Remove"
                            data-confirm-cancel="Cancel"
                          >
                            Remove Global
                          </button>
                        </form>
                        <form method="post" action="/admin/economy/items/delete" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="itemId" value="<%= it.itemId %>" />
                          <button
                            class="btn btn-outline-danger btn-sm"
                            type="submit"
                            data-confirm="Delete this item from the database and shop listings?"
                            data-confirm-title="Delete item?"
                            data-confirm-ok="Delete"
                            data-confirm-cancel="Cancel"
                          >
                            Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <script nonce="<%= cspNonce %>">
      (() => {
        const form = document.querySelector('[data-item-editor]');
        if (!form) return;

        const idInput = form.querySelector('[data-item-id-input]');
        const regenerateBtn = form.querySelector('[data-item-id-regenerate]');
        const imageInput = form.querySelector('[data-item-image-input]');
        const imageDataInput = form.querySelector('[data-item-image-data]');
        const imageUrlInput = form.querySelector('[name="imageUrl"]');
        const wallpaperUrlInput = form.querySelector('[name="wallpaperUrl"]');
        const preview = form.querySelector('[data-item-image-preview]');
        const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
        const currentPreviewSrc = String(preview?.dataset.currentSrc || '').trim();
        const currentPreviewFallbackSrc = String(preview?.dataset.currentFallbackSrc || '').trim();

        const generateId = () => {
          if (window.crypto?.getRandomValues) {
            const values = new Uint32Array(12);
            window.crypto.getRandomValues(values);
            return Array.from(values, (value) => alphabet[value % alphabet.length]).join('');
          }
          return Array.from({ length: 12 }, () => alphabet[Math.floor(Math.random() * alphabet.length)]).join('');
        };

        const ensureId = (force = false) => {
          if (!idInput) return;
          if (force || !String(idInput.value || '').trim()) idInput.value = generateId();
        };

        const setPreview = (src = '', label = 'No picture selected', fallbackSrc = '') => {
          if (!preview) return;
          if (!src) {
            preview.innerHTML = `<span>${label}</span>`;
            return;
          }
          const fallbackAttr = fallbackSrc && fallbackSrc !== src ? ` data-fallback-src="${fallbackSrc}"` : '';
          preview.innerHTML = `<img src="${src}" alt="Item preview"${fallbackAttr} />`;
        };

        const resolvePreviewSource = () => {
          const imageUrl = String(imageUrlInput?.value || '').trim();
          if (imageUrl) return imageUrl;
          const wallpaperUrl = String(wallpaperUrlInput?.value || '').trim();
          if (wallpaperUrl) return wallpaperUrl;
          return currentPreviewSrc;
        };

        const resolvePreviewFallbackSource = () => {
          const wallpaperUrl = String(wallpaperUrlInput?.value || '').trim();
          if (!String(imageUrlInput?.value || '').trim() && wallpaperUrl) return currentPreviewFallbackSrc || '';
          return currentPreviewFallbackSrc;
        };

        regenerateBtn?.addEventListener('click', () => ensureId(true));
        ensureId(false);
        setPreview(resolvePreviewSource(), 'No picture selected', resolvePreviewFallbackSource());

        const handleUrlPreview = () => {
          if (String(imageDataInput?.value || '').trim()) return;
          setPreview(resolvePreviewSource(), 'No picture selected', resolvePreviewFallbackSource());
        };

        imageUrlInput?.addEventListener('input', handleUrlPreview);
        wallpaperUrlInput?.addEventListener('input', handleUrlPreview);

        imageInput?.addEventListener('change', () => {
          const [file] = Array.from(imageInput.files || []);
          if (!file) {
            if (imageDataInput) imageDataInput.value = '';
            setPreview(resolvePreviewSource(), 'No picture selected', resolvePreviewFallbackSource());
            return;
          }

          const reader = new FileReader();
          reader.onload = () => {
            const result = typeof reader.result === 'string' ? reader.result : '';
            if (imageDataInput) imageDataInput.value = result;
            setPreview(result, file.name || 'Selected picture');
          };
          reader.readAsDataURL(file);
        });
      })();
    </script>
    <%- include('../../partials/footer') %>
  </body>
</html>
