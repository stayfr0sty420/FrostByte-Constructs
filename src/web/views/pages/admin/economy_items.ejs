<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page economy-items-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <section class="economy-items-hero mb-4">
        <div class="hero-eyebrow">Economy Inventory</div>
        <h1 class="hero-title mb-2">Items</h1>
        <p class="hero-text mb-0">Create, adjust, and review the latest economy items without losing readability on smaller screens.</p>
      </section>

      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h2 class="h6">Create / Update Item</h2>
          <form method="post" action="/admin/economy/items" class="row g-2 economy-item-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-4">
              <label class="form-label">itemId</label>
              <input class="form-control" name="itemId" required />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label">name</label>
              <input class="form-control" name="name" required />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label">type</label>
              <input class="form-control" name="type" required />
            </div>
            <div class="col-12">
              <label class="form-label">description</label>
              <input class="form-control" name="description" />
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">rarity</label>
              <input class="form-control" name="rarity" placeholder="common" required />
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label">price</label>
              <input class="form-control" name="price" type="number" min="0" value="0" />
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label">tags (comma separated)</label>
              <input class="form-control" name="tags" />
            </div>
            <div class="col-12 economy-item-flags">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="sellable" value="1" checked />
                <label class="form-check-label">sellable</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="consumable" value="1" />
                <label class="form-check-label">consumable</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="stackable" value="1" checked />
                <label class="form-check-label">stackable</label>
              </div>
              <div class="economy-item-submit">
                <button class="btn btn-primary" type="submit">Save</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h6 mb-3">Existing Items (latest 100)</h2>
          <div class="table-responsive economy-items-table-wrap">
            <table class="table table-sm align-middle economy-items-table">
              <thead>
                <tr>
                  <th>itemId</th>
                  <th>name</th>
                  <th>type</th>
                  <th>rarity</th>
                  <th class="text-end">price</th>
                </tr>
              </thead>
              <tbody>
                <% if (!items.length) { %>
                  <tr>
                    <td colspan="5" class="text-muted small">No items found yet. Create one above to populate the inventory.</td>
                  </tr>
                <% } %>
                <% items.forEach(it => { %>
                  <tr>
                    <td data-label="Item ID"><code><%= it.itemId %></code></td>
                    <td data-label="Name"><%= it.name %></td>
                    <td data-label="Type"><%= it.type %></td>
                    <td data-label="Rarity"><%= it.rarity %></td>
                    <td data-label="Price" class="text-end"><%= it.price %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
