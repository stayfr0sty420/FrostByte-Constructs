<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page economy-analytics-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <% const flowSeriesJson = JSON.stringify(flowSeries || []).replace(/</g, '\\u003c'); %>
      <% const fmtFull = (value) => Math.floor(Number(value || 0)).toLocaleString('en-US'); %>
      <% const fmtCompact = (value, threshold = 1000) => formatCompactNumber(value, { threshold }); %>

      <section class="dashboard-hero mb-4">
        <div class="dashboard-hero__copy">
          <div class="hero-eyebrow">RoBot Analytics</div>
          <h1 class="hero-title mb-2">Economy Overview</h1>
          <p class="hero-text mb-0">Track usage, coin flow, rarity distribution, and top players with toggles for global or server-focused analytics.</p>
        </div>
        <div class="dashboard-hero__actions">
          <div class="scope-switcher">
            <a class="btn btn-sm <%= analyticsScope === 'server' ? 'btn-primary' : 'btn-outline-secondary' %>" href="/admin/economy/analytics?scope=server">Per Server</a>
            <a class="btn btn-sm <%= analyticsScope === 'global' ? 'btn-primary' : 'btn-outline-secondary' %>" href="/admin/economy/analytics?scope=global">Global</a>
          </div>
        </div>
      </section>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Players</div>
              <div class="display-6" data-analytics-stat="players" title="<%= fmtFull(playerCount) %>"><%= fmtCompact(playerCount) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Coins Generated</div>
              <div class="display-6" data-analytics-stat="generated" title="<%= fmtFull(totals.generated) %>"><%= fmtCompact(totals.generated) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Coins Spent</div>
              <div class="display-6" data-analytics-stat="spent" title="<%= fmtFull(totals.spent) %>"><%= fmtCompact(totals.spent) %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Net Flow</div>
              <div class="display-6" data-analytics-stat="net" title="<%= fmtFull((totals.generated || 0) - (totals.spent || 0)) %>"><%= fmtCompact((totals.generated || 0) - (totals.spent || 0)) %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12">
          <div class="card shadow-sm analytics-flow-card">
            <div class="card-body">
              <div class="analytics-flow-header mb-3">
                <div>
                  <h2 class="h5 mb-1">Live Economy Flow</h2>
                  <div class="text-muted small">Generated, spent, and net credits over the last 24 hours for the current analytics scope.</div>
                </div>
                <div class="analytics-flow-meta">
                  <span class="badge text-bg-secondary">Auto refresh 30s</span>
                  <span class="text-muted small" data-flow-updated>Updated <%= analyticsUpdatedAt ? formatDate(analyticsUpdatedAt) : '—' %></span>
                </div>
              </div>

              <div class="analytics-flow-legend mb-3">
                <span class="analytics-flow-legend__item analytics-flow-legend__item--generated">Generated</span>
                <span class="analytics-flow-legend__item analytics-flow-legend__item--spent">Spent</span>
                <span class="analytics-flow-legend__item analytics-flow-legend__item--net">Net</span>
              </div>

              <div class="analytics-flow-chart" data-flow-chart data-live-url="<%= flowLiveUrl %>">
                <svg data-flow-chart-svg aria-label="Economy flow chart" role="img"></svg>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h2 class="h5 mb-3">Command / Activity Usage</h2>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 analytics-table">
                  <thead>
                    <tr>
                      <th>Type</th>
                      <th class="text-end">Uses</th>
                      <th class="text-end">Net Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!usage.length) { %>
                      <tr>
                        <td colspan="3" class="text-muted py-3">No tracked activity yet.</td>
                      </tr>
                    <% } %>
                    <% usage.forEach(entry => { %>
                      <tr>
                        <td data-label="Type"><code><%= entry._id %></code></td>
                        <td class="text-end" data-label="Uses" title="<%= fmtFull(entry.count) %>"><%= fmtCompact(entry.count) %></td>
                        <td class="text-end" data-label="Net Amount" title="<%= fmtFull(entry.net) %>"><%= fmtCompact(entry.net) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h2 class="h5 mb-3">Item Distribution by Rarity</h2>
              <div class="row g-3 analytics-rarity-grid">
                <% ['common','rare','epic','pristine','transcendent','primordial'].forEach(rarity => { %>
                  <div class="col-6 col-md-4">
                    <div class="analytics-rarity-card rarity-card rarity-card--<%= rarity %>">
                      <div class="text-uppercase text-muted small"><%= rarity %></div>
                      <div class="fs-4" title="<%= fmtFull(rarityTotals[rarity] || 0) %>"><%= fmtCompact(rarityTotals[rarity] || 0) %></div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <h2 class="h5 mb-0">Top Players</h2>
                <div class="text-muted small"><%= analyticsScope === 'global' ? 'Global users grouped by first RoBot server' : 'Users from the active server scope' %></div>
              </div>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 analytics-table">
                  <thead>
                    <tr>
                      <th>User</th>
                      <% if (showOriginServer) { %><th>Origin Server</th><% } %>
                      <th class="text-end">Wallet</th>
                      <th class="text-end">Bank</th>
                      <th class="text-end">Gear</th>
                      <th class="text-end">Level</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!topPlayers.length) { %>
                      <tr>
                        <td colspan="<%= showOriginServer ? 6 : 5 %>" class="text-muted py-3">No players yet.</td>
                      </tr>
                    <% } %>
                    <% topPlayers.forEach(player => { %>
                      <tr>
                        <td data-label="User">
                          <% if (player.profileHref) { %>
                            <a class="analytics-player-link" href="<%= player.profileHref %>"><%= player.username || player.discordId %></a>
                          <% } else { %>
                            <span><%= player.username || player.discordId %></span>
                          <% } %>
                          <div class="text-muted small"><code><%= player.discordId %></code></div>
                        </td>
                        <% if (showOriginServer) { %>
                          <td data-label="Origin Server"><%= player.originGuildName || 'Unknown' %></td>
                        <% } %>
                        <td class="text-end" data-label="Wallet" title="<%= fmtFull(player.balance) %>"><%= fmtCompact(player.balance) %></td>
                        <td class="text-end" data-label="Bank" title="<%= fmtFull(player.bank) %>"><%= fmtCompact(player.bank) %></td>
                        <td class="text-end" data-label="Gear" title="<%= fmtFull(player.gearScore) %>"><%= fmtCompact(player.gearScore) %></td>
                        <td class="text-end" data-label="Level" title="<%= fmtFull(player.level) %>"><%= fmtCompact(player.level) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5 mb-3">Top PvP Players</h2>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 analytics-table">
                  <thead>
                    <tr>
                      <th>User</th>
                      <% if (showOriginServer) { %><th>Origin Server</th><% } %>
                      <th class="text-end">Rating</th>
                      <th class="text-end">Wins</th>
                      <th class="text-end">Level</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!topPvp.length) { %>
                      <tr>
                        <td colspan="<%= showOriginServer ? 5 : 4 %>" class="text-muted py-3">No PvP data yet.</td>
                      </tr>
                    <% } %>
                    <% topPvp.forEach(player => { %>
                      <tr>
                        <td data-label="User">
                          <% if (player.profileHref) { %>
                            <a class="analytics-player-link" href="<%= player.profileHref %>"><%= player.username || player.discordId %></a>
                          <% } else { %>
                            <span><%= player.username || player.discordId %></span>
                          <% } %>
                          <div class="text-muted small"><code><%= player.discordId %></code></div>
                        </td>
                        <% if (showOriginServer) { %>
                          <td data-label="Origin Server"><%= player.originGuildName || 'Unknown' %></td>
                        <% } %>
                        <td class="text-end" data-label="Rating" title="<%= fmtFull(player.pvpRating) %>"><%= fmtCompact(player.pvpRating) %></td>
                        <td class="text-end" data-label="Wins" title="<%= fmtFull(player.pvpWins) %>"><%= fmtCompact(player.pvpWins) %></td>
                        <td class="text-end" data-label="Level" title="<%= fmtFull(player.level) %>"><%= fmtCompact(player.level) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <script nonce="<%= cspNonce %>">
      (() => {
        const chartRoot = document.querySelector('[data-flow-chart]');
        if (!chartRoot) return;

        const svg = chartRoot.querySelector('[data-flow-chart-svg]');
        const updatedLabel = document.querySelector('[data-flow-updated]');
        const liveUrl = chartRoot.getAttribute('data-live-url') || '';
        let series = <%- flowSeriesJson %>;

        const colors = {
          generated: '#22c55e',
          spent: '#f97316',
          net: '#38bdf8',
          grid: 'rgba(148, 163, 184, 0.18)',
          label: 'rgba(226, 232, 240, 0.72)',
          zero: 'rgba(248, 113, 113, 0.28)'
        };

        const formatNumber = (value) => Number(value || 0).toLocaleString('en-US');
        const escapeText = (value) =>
          String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const getChartMetrics = (rows) => {
          const chartWidth = Math.max(320, Math.round(chartRoot.clientWidth || 760));
          const measuredHeight = Math.round(svg.getBoundingClientRect().height || 0);
          const chartHeight = Math.max(260, measuredHeight || (chartWidth < 560 ? 260 : chartWidth < 900 ? 290 : 320));
          const values = rows.flatMap((row) => [Number(row.generated || 0), Number(row.spent || 0), Number(row.net || 0)]);
          const widestLabel = values.reduce((max, value) => Math.max(max, formatNumber(Math.round(value)).length), 1);
          const leftPad = Math.min(124, Math.max(84, widestLabel * (chartWidth < 560 ? 7.2 : 7.9) + 18));
          const rightPad = chartWidth < 560 ? 16 : 24;
          const topPad = 22;
          const bottomPad = chartWidth < 560 ? 46 : 42;
          return {
            width: chartWidth,
            height: chartHeight,
            pad: { top: topPad, right: rightPad, bottom: bottomPad, left: leftPad }
          };
        };

        const buildPoints = (rows, key, minValue, maxValue, metrics) => {
          const { width, height, pad } = metrics;
          const plotWidth = width - pad.left - pad.right;
          const plotHeight = height - pad.top - pad.bottom;
          const safeRange = Math.max(1, maxValue - minValue);
          const span = Math.max(1, rows.length - 1);
          return rows
            .map((row, index) => {
              const x = pad.left + (index / span) * plotWidth;
              const y = pad.top + ((maxValue - Number(row[key] || 0)) / safeRange) * plotHeight;
              return `${x.toFixed(2)},${y.toFixed(2)}`;
            })
            .join(' ');
        };

        const buildAreaPath = (rows, key, minValue, maxValue, metrics) => {
          if (!rows.length) return '';
          const { width, height, pad } = metrics;
          const plotHeight = height - pad.top - pad.bottom;
          const safeRange = Math.max(1, maxValue - minValue);
          const baselineY = pad.top + ((maxValue - 0) / safeRange) * plotHeight;
          const points = buildPoints(rows, key, minValue, maxValue, metrics)
            .split(' ')
            .filter(Boolean);
          if (!points.length) return '';
          const firstPoint = points[0]?.split(',') || [pad.left, baselineY];
          const lastPoint = points[points.length - 1]?.split(',') || [width - pad.right, baselineY];
          return [
            `M ${Number(firstPoint[0]).toFixed(2)} ${baselineY.toFixed(2)}`,
            ...points.map((point) => `L ${point.replace(',', ' ')}`),
            `L ${Number(lastPoint[0]).toFixed(2)} ${baselineY.toFixed(2)}`,
            'Z'
          ].join(' ');
        };

        const renderChart = (rows) => {
          const safeRows = Array.isArray(rows) ? rows : [];
          if (!safeRows.length) {
            svg.setAttribute('viewBox', '0 0 760 280');
            svg.innerHTML = `
              <g>
                <rect x="0" y="0" width="760" height="280" rx="22" fill="transparent"></rect>
                <text x="380" y="140" fill="${colors.label}" font-size="14" text-anchor="middle">No economy flow data yet.</text>
              </g>
            `;
            return;
          }

          const metrics = getChartMetrics(safeRows);
          const { width, height, pad } = metrics;
          const values = safeRows.flatMap((row) => [Number(row.generated || 0), Number(row.spent || 0), Number(row.net || 0)]);
          const minValue = Math.min(0, ...values);
          const maxValue = Math.max(1, ...values);
          const plotWidth = width - pad.left - pad.right;
          const plotHeight = height - pad.top - pad.bottom;
          const safeRange = Math.max(1, maxValue - minValue);
          const zeroY = pad.top + ((maxValue - 0) / safeRange) * plotHeight;
          const xLabelStep = width < 480 ? 8 : width < 640 ? 6 : width < 900 ? 4 : 3;

          svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
          svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

          const yTicks = Array.from({ length: 5 }, (_, index) => {
            const ratio = index / 4;
            const value = maxValue - safeRange * ratio;
            const y = pad.top + plotHeight * ratio;
            return { value, y };
          });

          const xLabels = safeRows
            .map((row, index) => {
              if (index !== 0 && index !== safeRows.length - 1 && index % xLabelStep !== 0) return '';
              const span = Math.max(1, safeRows.length - 1);
              const x = pad.left + (index / span) * plotWidth;
              const anchor = index === 0 ? 'start' : index === safeRows.length - 1 ? 'end' : 'middle';
              const labelX = index === 0 ? x + 2 : index === safeRows.length - 1 ? x - 2 : x;
              return `<text x="${labelX.toFixed(2)}" y="${height - 14}" fill="${colors.label}" font-size="11" text-anchor="${anchor}">${escapeText(row.label)}</text>`;
            })
            .filter(Boolean)
            .join('');

          const grid = yTicks
            .map(
              (tick) => `
                <line x1="${pad.left}" y1="${tick.y.toFixed(2)}" x2="${width - pad.right}" y2="${tick.y.toFixed(2)}" stroke="${colors.grid}" stroke-width="1" />
                <text x="${pad.left - 14}" y="${(tick.y + 4).toFixed(2)}" fill="${colors.label}" font-size="11" text-anchor="end">${escapeText(formatNumber(Math.round(tick.value)))}</text>
              `
            )
            .join('');

          const lastRow = safeRows[safeRows.length - 1] || {};
          const buildMarker = (key, color) => {
            const span = Math.max(1, safeRows.length - 1);
            const x = pad.left + plotWidth;
            const y = pad.top + ((maxValue - Number(lastRow[key] || 0)) / safeRange) * plotHeight;
            return `
              <circle cx="${x.toFixed(2)}" cy="${y.toFixed(2)}" r="4.5" fill="${color}" stroke="rgba(8, 6, 10, 0.9)" stroke-width="2" />
            `;
          };

          svg.innerHTML = `
            <g>
              <rect x="${pad.left}" y="${pad.top}" width="${plotWidth}" height="${plotHeight}" rx="18" fill="rgba(13, 10, 16, 0.48)" />
              ${grid}
              <line x1="${pad.left}" y1="${zeroY.toFixed(2)}" x2="${width - pad.right}" y2="${zeroY.toFixed(2)}" stroke="${colors.zero}" stroke-width="1.5" stroke-dasharray="6 6" />
              <path d="${buildAreaPath(safeRows, 'generated', minValue, maxValue, metrics)}" fill="rgba(34, 197, 94, 0.08)" />
              <path d="${buildAreaPath(safeRows, 'spent', minValue, maxValue, metrics)}" fill="rgba(249, 115, 22, 0.08)" />
              <path d="${buildAreaPath(safeRows, 'net', minValue, maxValue, metrics)}" fill="rgba(56, 189, 248, 0.08)" />
              <polyline fill="none" stroke="${colors.generated}" stroke-width="3.25" stroke-linecap="round" stroke-linejoin="round" points="${buildPoints(safeRows, 'generated', minValue, maxValue, metrics)}" />
              <polyline fill="none" stroke="${colors.spent}" stroke-width="3.25" stroke-linecap="round" stroke-linejoin="round" points="${buildPoints(safeRows, 'spent', minValue, maxValue, metrics)}" />
              <polyline fill="none" stroke="${colors.net}" stroke-width="3.25" stroke-linecap="round" stroke-linejoin="round" points="${buildPoints(safeRows, 'net', minValue, maxValue, metrics)}" />
              ${buildMarker('generated', colors.generated)}
              ${buildMarker('spent', colors.spent)}
              ${buildMarker('net', colors.net)}
              ${xLabels}
            </g>
          `;
        };

        const setUpdatedLabel = (value) => {
          if (!updatedLabel) return;
          const date = value ? new Date(value) : new Date();
          updatedLabel.textContent = `Updated ${date.toLocaleString('en-US', {
            month: 'long',
            day: 'numeric',
            year: 'numeric',
            hour: 'numeric',
            minute: '2-digit'
          })}`;
        };

        const refresh = async () => {
          if (!liveUrl) return;
          try {
            const response = await fetch(liveUrl, {
              headers: { Accept: 'application/json' },
              credentials: 'same-origin'
            });
            if (!response.ok) return;
            const payload = await response.json();
            if (!Array.isArray(payload?.series)) return;
            series = payload.series;
            renderChart(series);
            setUpdatedLabel(payload.updatedAt);
          } catch (_error) {}
        };

        renderChart(series);
        setUpdatedLabel(<%- JSON.stringify(analyticsUpdatedAt ? analyticsUpdatedAt.toISOString() : '') %>);
        if (window.ResizeObserver) {
          const resizeObserver = new ResizeObserver(() => renderChart(series));
          resizeObserver.observe(chartRoot);
        } else {
          window.addEventListener('resize', () => renderChart(series));
        }
        window.setInterval(refresh, 30000);
      })();
    </script>
    <%- include('../../partials/footer') %>
  </body>
</html>
