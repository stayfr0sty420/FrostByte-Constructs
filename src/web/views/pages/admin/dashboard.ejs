<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h4 m-0">Dashboard</h1>
        <a href="/admin/servers" class="btn btn-outline-secondary btn-sm">Change Server</a>
      </div>

      <% const status = (cfg.approval && cfg.approval.status) ? cfg.approval.status : 'pending'; %>
      <% const badge = status === 'approved' ? 'success' : (status === 'rejected' ? 'danger' : 'warning'); %>
      <div class="card shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div class="d-flex align-items-center gap-3">
            <span class="server-icon server-icon-lg" data-fallback="SV">
              <% if (activeGuildIcon) { %>
                <img src="<%= activeGuildIcon %>" alt="<%= cfg.guildName || cfg.guildId %> icon" loading="lazy" data-fallback-img />
              <% } %>
              <span class="server-icon-fallback"><%= (cfg.guildName || 'S').slice(0, 2).toUpperCase() %></span>
            </span>
            <div>
              <div class="fw-semibold"><%= cfg.guildName || cfg.guildId %></div>
              <div class="text-muted small">Guild ID: <code><%= cfg.guildId %></code></div>
            </div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge text-bg-<%= badge %>"><%= status %></span>
            <div class="d-flex align-items-center gap-2">
              <% (bots || []).forEach(b => { %>
                <span class="bot-icon-sm <%= b.status %>" title="<%= b.name %>: <%= b.status %>">
                  <img src="<%= b.icon %>" alt="<%= b.name %> logo" loading="lazy" />
                  <span class="bot-status-dot <%= b.status %>"></span>
                </span>
              <% }) %>
            </div>
            <a href="/admin/servers" class="btn btn-outline-primary btn-sm">Approvals</a>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-12 col-md-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="text-muted">Users</div>
              <div class="display-6"><%= stats.usersCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="text-muted">Backups</div>
              <div class="display-6"><%= stats.backupsCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="text-muted">Pending Verifications</div>
              <div class="display-6"><%= stats.pendingCount %></div>
            </div>
          </div>
        </div>
      </div>

    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
