<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page dashboard-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <section class="dashboard-hero mb-4">
        <div class="dashboard-hero__copy">
          <div class="hero-eyebrow">Admin Overview</div>
          <h1 class="hero-title mb-2">Dashboard</h1>
          <p class="hero-text mb-0">Review the selected server, connected bot status, and key activity totals in one place.</p>
        </div>
        <div class="dashboard-hero__actions">
          <a href="/admin/servers" class="btn btn-outline-secondary btn-sm">Change Server</a>
        </div>
      </section>

      <div class="card shadow-sm mb-3 dashboard-server-card">
        <div class="card-body dashboard-server-card__body">
          <div class="dashboard-server-card__identity">
            <span class="server-icon server-icon-lg" data-fallback="SV">
              <% if (activeGuildIcon) { %>
                <img src="<%= activeGuildIcon %>" alt="<%= cfg.guildName || cfg.guildId %> icon" loading="lazy" data-fallback-img />
              <% } %>
              <span class="server-icon-fallback"><%= (cfg.guildName || 'S').slice(0, 2).toUpperCase() %></span>
            </span>
            <div class="dashboard-server-card__meta">
              <div class="fw-semibold"><%= cfg.guildName || cfg.guildId %></div>
              <div class="text-muted small">Guild ID: <code><%= cfg.guildId %></code></div>
            </div>
          </div>
          <div class="dashboard-server-card__aside">
            <div class="dashboard-bot-strip">
              <% (bots || []).forEach(b => { %>
                <span class="bot-icon-sm <%= b.status %><%= b.key === 'verification' ? ' bot-icon-sm--website' : '' %>" title="<%= b.name %>: <%= b.status %>">
                  <img src="<%= b.icon %>" alt="<%= b.name %> logo" loading="lazy" />
                  <span class="bot-status-dot <%= b.status %>"></span>
                </span>
              <% }) %>
            </div>
            <a href="/admin/servers" class="btn btn-outline-primary btn-sm">Approvals</a>
          </div>
        </div>
      </div>

      <div class="row g-3 dashboard-stats">
        <div class="col-12 col-sm-6">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Members</div>
              <div class="display-6"><%= stats.usersCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6">
          <div class="card shadow-sm dashboard-stat-card">
            <div class="card-body">
              <div class="dashboard-stat-card__label">Backups</div>
              <div class="display-6"><%= stats.backupsCount %></div>
            </div>
          </div>
        </div>
      </div>

    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
