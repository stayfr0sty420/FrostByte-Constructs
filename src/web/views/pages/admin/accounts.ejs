<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page accounts-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <section class="accounts-hero mb-4">
        <div>
          <div class="accounts-kicker">Owner Controls</div>
          <h1 class="h3 mb-2">Admin Accounts</h1>
          <p class="accounts-subtitle mb-0">
            Add, disable, or permanently delete dashboard admins. New accounts are saved in MongoDB, removed accounts lose access
            immediately, and every account change is recorded in the audit log below.
          </p>
        </div>
      </section>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %> accounts-alert"><%= flash.message %></div>
      <% } %>

      <section class="accounts-stat-grid mb-4">
        <article class="accounts-stat-card">
          <div class="accounts-stat-label">Total Accounts</div>
          <div class="accounts-stat-value"><%= stats.total %></div>
        </article>
        <article class="accounts-stat-card">
          <div class="accounts-stat-label">Active</div>
          <div class="accounts-stat-value"><%= stats.active %></div>
        </article>
        <article class="accounts-stat-card">
          <div class="accounts-stat-label">Disabled</div>
          <div class="accounts-stat-value"><%= stats.disabled %></div>
        </article>
        <article class="accounts-stat-card">
          <div class="accounts-stat-label">Prime Accounts</div>
          <div class="accounts-stat-value"><%= stats.owners %></div>
        </article>
      </section>

      <div class="row g-3 align-items-start">
        <div class="col-12 col-xl-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                <div>
                  <h2 class="h5 mb-1">Add Account</h2>
                  <p class="accounts-panel-copy mb-0">
                    New admins will create their own Google Authenticator setup on first login.
                  </p>
                </div>
                <span class="badge text-bg-secondary">MongoDB</span>
              </div>

              <form method="post" action="/admin/accounts" class="row g-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="col-12">
                  <label class="form-label">Name</label>
                  <input class="form-control" type="text" name="name" placeholder="Admin name" required />
                </div>
                <div class="col-12">
                  <label class="form-label">Email</label>
                  <input class="form-control" type="email" name="email" placeholder="admin@example.com" required />
                </div>
                <div class="col-12">
                  <label class="form-label">Password</label>
                  <input class="form-control" type="password" name="password" required />
                  <div class="form-text">Minimum 10 characters with uppercase, lowercase, and a number.</div>
                </div>
                <div class="col-12">
                  <label class="form-label">Role</label>
                  <select class="form-select" name="role">
                    <option value="admin" selected>Administrator</option>
                    <% if (isOwner) { %>
                      <option value="owner">Prime 👑</option>
                    <% } %>
                  </select>
                  <% if (!isOwner) { %>
                    <div class="form-text">Administrators can add only Administrator accounts.</div>
                  <% } %>
                </div>
                <div class="col-12">
                  <div class="accounts-form-note">
                    Deleted accounts are removed from the admin database and cannot log in again unless recreated.
                  </div>
                </div>
                <div class="col-12 d-grid">
                  <button class="btn btn-primary" type="submit">Create Account</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-8">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                <div>
                  <h2 class="h5 mb-1">Existing Accounts</h2>
                  <p class="accounts-panel-copy mb-0">Disable for temporary access removal or delete to remove the account from MongoDB.</p>
                </div>
                <span class="badge text-bg-dark"><%= stats.active %> active now</span>
              </div>

              <div class="table-responsive accounts-table-wrap">
                <table class="table table-sm align-middle mb-0 accounts-table">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Role</th>
                      <th>Status</th>
                      <th>Last Login</th>
                      <th class="text-end">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!users.length) { %>
                      <tr>
                        <td colspan="6" class="text-muted text-center py-4">No admin accounts found.</td>
                      </tr>
                    <% } %>
                    <% users.forEach((u) => { %>
                      <tr>
                        <td data-label="Name">
                          <div class="fw-semibold"><%= u.name || '—' %></div>
                        </td>
                        <td data-label="Email">
                          <div class="fw-semibold accounts-email"><%= u.email %></div>
                        </td>
                        <td data-label="Role">
                          <span class="badge text-bg-secondary"><%= formatAdminRole(u.role) %></span>
                        </td>
                        <td data-label="Status">
                          <% if (u.disabled) { %>
                            <span class="badge text-bg-danger">disabled</span>
                          <% } else { %>
                            <span class="badge text-bg-success">active</span>
                          <% } %>
                          <% if (String(u._id) === meId) { %>
                            <span class="badge text-bg-info ms-1">you</span>
                          <% } %>
                        </td>
                        <td data-label="Last Login">
                          <span class="accounts-last-login"><%= u.lastLoginAt ? formatDate(u.lastLoginAt) : 'Never' %></span>
                        </td>
                        <td class="text-end accounts-actions-cell" data-label="Actions">
                          <% if (isOwner && String(u._id) !== meId) { %>
                            <div class="accounts-actions">
                              <a class="btn btn-outline-light btn-sm" href="/admin/accounts/<%= u._id %>">Manage</a>
                              <% if (u.disabled) { %>
                                <form method="post" action="/admin/accounts/enable/<%= u._id %>">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                  <button class="btn btn-outline-success btn-sm" type="submit">Enable</button>
                                </form>
                              <% } else { %>
                                <form method="post" action="/admin/accounts/disable/<%= u._id %>">
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                  <button
                                    class="btn btn-outline-warning btn-sm"
                                    type="submit"
                                    data-confirm="Disable this account?"
                                    data-confirm-title="Disable account?"
                                    data-confirm-ok="Disable"
                                    data-confirm-cancel="Cancel"
                                  >
                                    Disable
                                  </button>
                                </form>
                              <% } %>
                              <form method="post" action="/admin/accounts/delete/<%= u._id %>">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <button
                                  class="btn btn-outline-danger btn-sm"
                                  type="submit"
                                  data-confirm="Delete this account from the database? This admin will lose login access immediately."
                                  data-confirm-title="Delete account?"
                                  data-confirm-ok="Delete"
                                  data-confirm-cancel="Cancel"
                                >
                                  Delete
                                </button>
                              </form>
                            </div>
                          <% } else if (isOwner) { %>
                            <span class="text-muted small">Current account</span>
                          <% } else { %>
                            <span class="text-muted small">Prime only</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <section class="card shadow-sm mt-4">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
            <div>
              <h2 class="h5 mb-1">Recent Account Audit</h2>
              <p class="accounts-panel-copy mb-0">Latest create, disable, enable, and delete actions stored in the admin logs collection.</p>
            </div>
            <span class="badge text-bg-dark"><%= auditLogs.length %> recent entries</span>
          </div>

          <% if (!auditLogs.length) { %>
            <div class="accounts-empty-state text-muted">No account audit entries yet.</div>
          <% } else { %>
            <div class="accounts-activity-list">
              <% auditLogs.forEach((log) => { %>
                <%
                  const stageLabel = String(log.stage || '')
                    .replace(/^account-/, '')
                    .split('-')
                    .filter(Boolean)
                    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
                    .join(' ');
                %>
                <article class="accounts-activity-item">
                  <div class="accounts-activity-meta">
                    <span class="badge <%= log.status === 'failed' ? 'text-bg-danger' : 'text-bg-secondary' %>"><%= stageLabel || 'Account Update' %></span>
                    <span class="accounts-activity-time"><%= formatDate(log.createdAt) || '' %></span>
                  </div>
                  <div class="accounts-activity-message"><%= log.reason || 'No details.' %></div>
                  <div class="accounts-activity-actor">By <strong><%= log.email || 'system' %></strong></div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
