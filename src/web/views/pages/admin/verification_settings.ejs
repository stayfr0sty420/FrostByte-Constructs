<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page verification-settings-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <%
        const logConfigSections = Array.isArray(logSections) ? logSections : [];
        const logChannelMap = logChannelOverrides || {};
      %>
      <h1 class="h4 mb-3">Verification Settings</h1>

      <% if (flash) { %>
        <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.message %></div>
      <% } %>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h6 mb-2">Setup Checklist</h2>
          <ol class="mb-0">
            <li>Make sure this server is <strong>Approved</strong> in <a href="/admin/servers">Servers</a>.</li>
            <li>Create roles: <code>Unverified</code> (temp) and <code>Verified</code>.</li>
            <li>Move the Verification bot role <strong>above</strong> those roles (role hierarchy).</li>
            <li>Give Verification <strong>Manage Roles</strong> permission.</li>
            <li>Enable intents (Developer Portal): <strong>Server Members</strong> + <strong>Message Content</strong>.</li>
            <li>Set Temp Role + Verified Role below, then enable verification.</li>
            <li>Optional: enable the Verification Panel to post a Verify button in a channel.</li>
          </ol>
          <div class="text-muted small mt-2">
            Location checks now use network/IP lookup by default. If a browser has already allowed device GPS, the verification flow can attach that more precise reading automatically. HTTPS is still required for any browser geolocation capture.
          </div>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <form method="post" action="/admin/verification/settings" class="row g-2" id="verificationForm" data-autosave="1">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <div class="col-12 d-flex flex-wrap align-items-center justify-content-between gap-2">
              <h2 class="h6 mb-0">Core Settings</h2>
              <div class="text-muted small" data-autosave-status>Auto-save enabled</div>
            </div>

            <div class="col-12 d-flex gap-2 align-items-center">
              <div class="form-check form-switch">
                <input
                  class="form-check-input"
                  type="checkbox"
                  role="switch"
                  name="enabled"
                  value="1"
                  <%= cfg.verification.enabled ? 'checked' : '' %>
                />
                <label class="form-check-label">Enabled</label>
              </div>

              <div class="form-check form-switch ms-3">
                <input
                  class="form-check-input"
                  type="checkbox"
                  role="switch"
                  name="requireLocation"
                  value="1"
                  <%= (typeof cfg.verification.requireLocation === 'boolean' ? cfg.verification.requireLocation : true) ? 'checked' : '' %>
                />
                <label class="form-check-label">Require location check</label>
              </div>

              <div class="form-check form-switch ms-3">
                <input
                  class="form-check-input"
                  type="checkbox"
                  role="switch"
                  name="autoApprove"
                  value="1"
                  <%= (typeof cfg.verification.autoApprove === 'boolean' ? cfg.verification.autoApprove : true) ? 'checked' : '' %>
                />
                <label class="form-check-label">Auto-approve (give role)</label>
              </div>
            </div>

            <div class="col-12">
              <div class="text-muted small">
                Members no longer get stuck on a forced browser location pop-up. Verification records network location automatically and only adds precise device GPS when that browser already has permission.
              </div>
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label">Temp Role (Join Gate)</label>
              <select
                class="form-select role-select wick-select-native"
                name="tempRoleId"
                id="tempRoleId"
                data-role-select
                data-wick-select="role"
                data-placeholder="Select a temp role"
                data-search-placeholder="Search roles..."
              >
                <option value="">(none)</option>
                <% roles.forEach(r => { %>
                  <% const colorHex = r.color ? `#${r.color.toString(16).padStart(6, '0')}` : ''; %>
                  <option value="<%= r.id %>" data-color="<%= colorHex %>" <%= cfg.verification.tempRoleId === r.id ? 'selected' : '' %>>
                    <%= r.name %>
                  </option>
                <% }) %>
              </select>
              <div class="role-preview mt-2" data-role-preview="tempRoleId"></div>
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label">Verified Role</label>
              <select
                class="form-select role-select wick-select-native"
                name="verifiedRoleId"
                id="verifiedRoleId"
                data-role-select
                data-wick-select="role"
                data-placeholder="Select a verified role"
                data-search-placeholder="Search roles..."
              >
                <option value="">(none)</option>
                <% roles.forEach(r => { %>
                  <% const colorHex = r.color ? `#${r.color.toString(16).padStart(6, '0')}` : ''; %>
                  <option value="<%= r.id %>" data-color="<%= colorHex %>" <%= cfg.verification.verifiedRoleId === r.id ? 'selected' : '' %>>
                    <%= r.name %>
                  </option>
                <% }) %>
              </select>
              <div class="role-preview mt-2" data-role-preview="verifiedRoleId"></div>
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label">Log Channel (Verification)</label>
              <select
                class="form-select wick-select-native"
                name="logChannelId"
                id="logChannelId"
                data-wick-select="channel"
                data-placeholder="Select a log channel"
                data-search-placeholder="Search channels..."
              >
                <option value="">(none)</option>
                <% channels.forEach(c => { %>
                  <option value="<%= c.id %>" <%= cfg.verification.logChannelId === c.id ? 'selected' : '' %>>
                    <%= c.name %>
                  </option>
                <% }) %>
              </select>
              <div class="form-text">Default audit destination for verification logs. You can override each action below.</div>
            </div>

            <div class="col-12"><hr /></div>

            <div class="col-12">
              <h2 class="h6 mb-2">Verification Panel</h2>
              <div class="row g-2 align-items-start">
                <div class="col-12 col-md-4">
                  <div class="form-check form-switch">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      role="switch"
                      name="panelEnabled"
                      value="1"
                      <%= cfg.verification.panelEnabled ? 'checked' : '' %>
                    />
                    <label class="form-check-label">Post verify panel</label>
                  </div>
                  <div class="text-muted small mt-2">
                    Posts a Verify button so members can verify without running <code>/verify</code>.
                  </div>
                </div>
                <div class="col-12 col-md-8">
                  <label class="form-label">Panel Channel</label>
                  <select
                    class="form-select wick-select-native"
                    name="panelChannelId"
                    id="panelChannelId"
                    data-wick-select="channel"
                    data-placeholder="Select a panel channel"
                    data-search-placeholder="Search channels..."
                  >
                    <option value="">(select a channel)</option>
                    <% channels.forEach(c => { %>
                      <option value="<%= c.id %>" <%= cfg.verification.panelChannelId === c.id ? 'selected' : '' %>>
                        <%= c.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12 d-flex flex-wrap align-items-center gap-2">
                  <button class="btn btn-outline-primary btn-sm" type="submit" name="panelPost" value="1">
                    Post Panel Now
                  </button>
                  <span class="text-muted small">Use this to re-post the verify panel if it was deleted.</span>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="text-muted small">
                If <strong>Auto-approve</strong> is ON, members receive the Verified role immediately after completing the website + Discord OAuth2.
                Risk scoring is still logged for monitoring.
              </div>
            </div>

            <div class="col-12">
              <h2 class="h6 mb-2">Verification Questions</h2>
              <div class="text-muted small mb-2">
                Leave this empty for questionless verification. Optional acceptable answers can be added one per line for each question.
              </div>
              <div class="question-list" data-question-list>
                <% (questionConfigs || []).forEach((item) => { %>
                  <div class="question-row">
                    <div class="question-fields d-grid gap-2">
                      <input class="form-control" name="questionPrompt" value="<%= item.prompt %>" placeholder="Enter a question" />
                      <textarea class="form-control" name="questionAcceptableAnswers" rows="2" placeholder="Acceptable answers, one per line"><%= (item.acceptableAnswers || []).join('\n') %></textarea>
                    </div>
                    <button class="btn btn-outline-danger btn-sm icon-btn question-remove-btn" type="button" data-question-remove aria-label="Remove question">🗑️</button>
                  </div>
                <% }) %>
              </div>
              <button class="btn btn-outline-primary btn-sm mt-2" type="button" data-question-add>Add Question</button>
            </div>

            <div class="col-12"><hr /></div>

            <div class="col-12">
              <h2 class="h6 mb-2">Log Toggles</h2>
              <div class="text-muted small mb-3">Each event can now be routed to its own channel. Leave the selector empty to keep using the default verification log channel above.</div>
              <% logConfigSections.forEach((section) => { %>
                <div class="log-section">
                  <div class="log-section-title"><%= section.title %></div>
                  <div class="row g-2 log-grid">
                    <% section.items.forEach((item) => { %>
                      <% const selectedChannelId = logChannelMap[item.key] || ''; %>
                      <div class="col-12">
                        <div class="log-item log-item--channel">
                          <div class="form-check form-switch log-item-toggle">
                            <input
                              class="form-check-input"
                              type="checkbox"
                              role="switch"
                              name="<%= item.toggleField %>"
                              value="1"
                              <%= cfg.logs[item.toggleField] ? 'checked' : '' %>
                            />
                            <label class="form-check-label"><%= item.label %></label>
                          </div>
                          <div class="log-item-channel">
                            <select
                              class="form-select wick-select-native"
                              name="channelOverride_<%= item.key %>"
                              data-wick-select="channel"
                              data-placeholder="Use default verification log channel"
                              data-search-placeholder="Search channels..."
                            >
                              <option value="">Use default verification log channel</option>
                              <% channels.forEach((channel) => { %>
                                <option value="<%= channel.id %>" <%= selectedChannelId === channel.id ? 'selected' : '' %>>
                                  <%= channel.name %>
                                </option>
                              <% }) %>
                            </select>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>

            <div class="col-12 d-flex">
              <button class="btn btn-primary ms-auto" type="submit">Save</button>
            </div>
          </form>
        </div>
      </div>

      <div class="card shadow-sm mt-3">
        <div class="card-body">
          <h2 class="h6 mb-2">Test Actions</h2>
          <p class="text-muted small mb-3">
            Use this to test role assignment (make sure the bot role is above the target roles).
          </p>
          <div class="row g-2">
            <div class="col-12 col-md-6">
              <form method="post" action="/admin/verification/test/temp-role" class="d-flex gap-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input class="form-control" name="userId" placeholder="User ID" required />
                <button class="btn btn-outline-secondary" type="submit">Temp Role</button>
              </form>
            </div>
            <div class="col-12 col-md-6">
              <form method="post" action="/admin/verification/test/verified-role" class="d-flex gap-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input class="form-control" name="userId" placeholder="User ID" required />
                <button class="btn btn-outline-success" type="submit">Verified Role</button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex flex-wrap gap-2 mt-3">
        <a class="btn btn-outline-primary btn-sm" href="/admin/verification/iplogs">IP Logs</a>
      </div>
    </main>
    <div class="autosave-dock" data-autosave-dock>
      <div class="autosave-dock-label">Touch Save</div>
      <div class="autosave-dock-status" data-autosave-status-floating>Auto-save enabled</div>
    </div>
    <%- include('../../partials/footer') %>
    <script src="/assets/js/verification-settings.js"></script>
  </body>
</html>
