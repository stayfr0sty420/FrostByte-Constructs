<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="app admin-page">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h1 class="h4 m-0">Logs</h1>
          <div class="text-muted small">Latest activity from verification, backups, economy, and moderation.</div>
        </div>
        <a href="/admin/dashboard" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <div class="input-group input-group-sm log-search">
              <span class="input-group-text">Search</span>
              <input class="form-control" type="search" placeholder="Search logs..." data-log-search />
            </div>
            <div class="text-muted small" data-log-count></div>
          </div>

          <div class="log-list">
            <div class="log-empty text-muted small" data-log-empty style="<%= logs.length ? 'display:none;' : '' %>">No logs yet.</div>
            <% logs.forEach(l => { %>
              <%
                const embeds = Array.isArray(l.data?.embeds) ? l.data.embeds : [];
                const storedBot = String(l.bot || l.data?.bot || '').trim();
                const typeKey = String(l.type || '').toLowerCase();
                const fallbackBot = typeKey.includes('economy')
                  ? 'RoBot'
                  : typeKey.includes('backup')
                    ? 'Rodstarkian Vault'
                    : typeKey.includes('verification') || typeKey.includes('member') || typeKey.includes('message') || typeKey.includes('role') || typeKey.includes('channel') || typeKey.includes('voice')
                      ? "God's Eye"
                      : '';
                const botLabel = storedBot || fallbackBot;
                const embedText = embeds
                  .map((e) => {
                    const fields = Array.isArray(e.fields) ? e.fields : [];
                    const fieldText = fields.map((f) => `${f.name || ''} ${f.value || ''}`).join(' ');
                    return `${e.title || ''} ${e.description || ''} ${fieldText}`;
                  })
                  .join(' ');
                const typeLabel = String(l.type || '').split('_').join(' ');
                const jsonSearch = JSON.stringify(l.data || {}).slice(0, 2000);
                const rawSearch = `${botLabel} ${l.type || ''} ${l.data?.content || ''} ${embedText} ${jsonSearch}`;
                const searchText = String(rawSearch || '').toLowerCase();

                const summaryLines = [];
                const allowedFields = new Set(['user', 'status', 'risk', 'ip', 'location', 'note', 'result', 'action', 'type']);
                embeds.forEach((e) => {
                  if (e?.title) summaryLines.push(String(e.title));
                  if (e?.description) summaryLines.push(String(e.description));
                  const fields = Array.isArray(e.fields) ? e.fields : [];
                  fields.forEach((f) => {
                    const fieldName = String(f?.name || '').trim();
                    if (!allowedFields.has(fieldName.toLowerCase())) return;
                    const val = String(f?.value || '').trim();
                    if (!val) return;
                    summaryLines.push(`${fieldName}: ${val}`);
                  });
                });
                const clippedLines = summaryLines.filter(Boolean).slice(0, 6);
              %>
              <article class="log-card log-card-compact" data-log-row data-search="<%= searchText %>">
                <header class="log-card-header">
                  <div class="d-flex align-items-center gap-2 flex-wrap">
                    <% if (botLabel) { %>
                      <span class="badge text-bg-secondary log-bot"><%= botLabel %></span>
                    <% } %>
                    <div class="log-type"><%= typeLabel || l.type %></div>
                  </div>
                  <div class="log-meta">
                    <div class="log-time"><%= formatDate(l.createdAt) || '' %></div>
                    <form method="post" action="/admin/logs/delete/<%= l._id %>" class="d-inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button
                        class="btn btn-outline-danger btn-sm icon-btn"
                        type="submit"
                        title="Delete log"
                        aria-label="Delete log"
                        data-confirm="Delete this log entry?">
                        🗑️
                      </button>
                    </form>
                  </div>
                </header>
                <div class="log-card-body">
                  <% if (l.data?.content) { %>
                    <div class="log-content"><%= l.data.content %></div>
                  <% } %>
                  <% if (clippedLines.length) { %>
                    <div class="log-summary">
                      <% clippedLines.forEach((line) => { %>
                        <% const trimmed = String(line || '').trim(); %>
                        <% const lowered = trimmed.toLowerCase(); %>
                        <% const isLink = lowered.startsWith('http://') || lowered.startsWith('https://'); %>
                        <% if (isLink) { %>
                          <div><a class="link-danger" href="<%= trimmed %>" target="_blank" rel="noreferrer"><%= trimmed %></a></div>
                        <% } else { %>
                          <div><%= line %></div>
                        <% } %>
                      <% }) %>
                    </div>
                  <% } %>
                  <% if (!l.data?.content && !clippedLines.length) { %>
                    <div class="text-muted small">No details.</div>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>
