<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <%- include('../partials/head', { title }) %>
  </head>
  <body class="app landing auth-page">
    <main class="container py-5 landing-stage">
      <div class="float-orb orb-1"></div>
      <div class="float-orb orb-2"></div>
      <div class="float-orb orb-3"></div>

      <header class="landing-header">
        <div class="brand">
          <div class="brand-icon" data-fallback="RS">
            <img src="/assets/images/bots/Rodstarkian_Bot.png" alt="Rodstarkian Bot logo" loading="lazy" data-fallback-img />
            <span class="brand-fallback">RS</span>
          </div>
          <div>
            <div class="brand-title">Rodstarkian Suite</div>
            <div class="brand-sub">Admin Portal</div>
          </div>
        </div>
        <div class="header-actions header-switcher" role="navigation" aria-label="Portal switcher">
          <a class="header-switcher__link" href="/">User Login</a>
          <a class="header-switcher__link" href="/admin/login" aria-current="page">Admin Login</a>
        </div>
      </header>

      <div class="landing-grid auth-grid">
        <section class="hero-copy">
          <div class="hero-eyebrow">Restricted Access</div>
          <h1 class="hero-title">Secure Admin Authentication</h1>
          <p class="hero-text">
            This portal is reserved for approved admin emails only. Password login is protected with Google Authenticator,
            account lockouts, rate limiting, and audit logging.
          </p>
          <div class="hero-meta text-muted small">
            <span>Use your assigned admin email and a strong password.</span>
          </div>
        </section>

        <aside class="glass-card auth-card" data-admin-passkey data-options-url="/admin/passkey/options" data-verify-url="/admin/passkey/verify" data-csrf="<%= csrfToken %>" data-return-to="<%= returnTo %>">
          <% if (viewMode === '2fa-setup-intro') { %>
            <h2 class="h5 mb-2">Set Up Google Authenticator</h2>
            <p class="text-muted small mb-3">Before admin access is granted, scan a QR code once to enable your 6-digit TOTP login.</p>
          <% } else if (viewMode === '2fa-setup') { %>
            <h2 class="h5 mb-2">Scan Your QR Code</h2>
            <p class="text-muted small mb-3">Open Google Authenticator, scan the QR, then enter the current 6-digit code below.</p>
          <% } else if (viewMode === '2fa-verify') { %>
            <h2 class="h5 mb-2">Enter 2FA Code</h2>
            <p class="text-muted small mb-3">Use the 6-digit code from Google Authenticator to finish admin login.</p>
          <% } else if (viewMode === 'passkey-start') { %>
            <h2 class="h5 mb-2">Login with Passkey</h2>
            <p class="text-muted small mb-3">Use a saved passkey on this device, or scan the browser-provided QR prompt from another device.</p>
          <% } else if (viewMode === 'forgot-password') { %>
            <h2 class="h5 mb-2">Forgot Password</h2>
            <p class="text-muted small mb-3">Request a 60-second password reset OTP for your approved admin email.</p>
          <% } else if (viewMode === 'authenticator-start') { %>
            <h2 class="h5 mb-2">Login with Authenticator</h2>
            <p class="text-muted small mb-3">Enter your admin email, then use your current authenticator code or a backup code.</p>
          <% } else if (viewMode === 'verify-reset-otp') { %>
            <h2 class="h5 mb-2">Verify Reset OTP</h2>
            <p class="text-muted small mb-3">Enter the 6-digit code sent to your admin email.</p>
          <% } else if (viewMode === '2fa-backup') { %>
            <h2 class="h5 mb-2">Use Backup Code</h2>
            <p class="text-muted small mb-3">Enter one of your unused backup codes to finish admin login.</p>
          <% } else if (viewMode === 'reset-password') { %>
            <h2 class="h5 mb-2">Reset Password</h2>
            <p class="text-muted small mb-3">Set a new strong password to regain admin access.</p>
          <% } else { %>
            <h2 class="h5 mb-2">Login</h2>
            <p class="text-muted small mb-3">Enter your admin email and password.</p>
          <% } %>

          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
          <% } %>
          <div class="alert alert-info d-none" data-passkey-status></div>

          <% if (viewMode === '2fa-setup-intro') { %>
            <form method="post" action="/admin/2fa/setup" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="challengeToken" value="<%= challengeToken %>" />
              <div class="form-text text-start">Admin email: <strong><%= email %></strong></div>
              <button class="btn btn-primary w-100" type="submit">Generate QR Setup</button>
              <a class="btn btn-ghost w-100" href="/admin/login">Start Over</a>
            </form>
          <% } else if (viewMode === '2fa-setup') { %>
            <div class="text-center mb-3">
              <img
                src="<%= qrCodeDataUrl %>"
                alt="Google Authenticator QR code"
                class="img-fluid rounded-4 border border-danger-subtle bg-white p-3"
                style="max-width: 260px;"
              />
            </div>
            <form method="post" action="/admin/2fa/verify" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="authToken" value="<%= setupToken %>" />
              <div>
                <label class="form-label">6-Digit Authenticator Code</label>
                <input class="form-control" type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" autocomplete="one-time-code" autocapitalize="off" autocorrect="off" spellcheck="false" enterkeyhint="done" required />
              </div>
              <div class="form-text text-start">
                Manual Setup Key:
                <strong><%= setupKey %></strong>
              </div>
              <button class="btn btn-primary w-100" type="submit">Enable 2FA & Login</button>
            </form>
          <% } else if (viewMode === '2fa-verify') { %>
            <form method="post" action="/admin/2fa/verify" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="authToken" value="<%= challengeToken %>" />
              <div class="form-text text-start">Admin email: <strong><%= email %></strong></div>
              <div>
                <label class="form-label">6-Digit Authenticator Code</label>
                <input class="form-control" type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" autocomplete="one-time-code" autocapitalize="off" autocorrect="off" spellcheck="false" enterkeyhint="done" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Verify & Login</button>
              <a class="auth-inline-link text-center" href="/admin/login?mode=forgot-password">Forgot Password</a>
            </form>
            <form method="post" action="/admin/2fa/backup" class="d-grid gap-3 mt-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="authToken" value="<%= challengeToken %>" />
              <input type="hidden" name="email" value="<%= email %>" />
              <div>
                <label class="form-label">Or Use Backup Code</label>
                <input class="form-control" type="text" name="backupCode" placeholder="ABCD-EFGH" autocomplete="one-time-code" autocapitalize="characters" autocorrect="off" spellcheck="false" required />
              </div>
              <button class="btn btn-outline-light w-100" type="submit">Verify Backup Code</button>
            </form>
          <% } else if (viewMode === 'passkey-start') { %>
            <div class="d-grid gap-3 auth-form">
              <button class="btn btn-primary w-100" type="button" data-passkey-login>Continue with Passkey / QR</button>
              <div class="form-text text-start">Passkeys work on HTTPS or localhost and can open a QR flow automatically when your passkey is on another device.</div>
              <a class="btn btn-ghost w-100" href="/admin/login">Back to Password Login</a>
            </div>
          <% } else if (viewMode === 'authenticator-start') { %>
            <form method="post" action="/admin/authenticator" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="returnTo" value="<%= returnTo %>" />
              <div>
                <label class="form-label">Admin Email</label>
                <input class="form-control" type="email" name="email" value="<%= email %>" placeholder="admin@example.com" autocomplete="email" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Continue with Authenticator</button>
              <a class="btn btn-ghost w-100" href="/admin/login">Back to Password Login</a>
            </form>
          <% } else if (viewMode === '2fa-backup') { %>
            <form method="post" action="/admin/2fa/backup" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="authToken" value="<%= challengeToken %>" />
              <div class="form-text text-start">Admin email: <strong><%= email %></strong></div>
              <div>
                <label class="form-label">Backup Code</label>
                <input class="form-control" type="text" name="backupCode" placeholder="ABCD-EFGH" autocomplete="one-time-code" autocapitalize="characters" autocorrect="off" spellcheck="false" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Verify Backup Code</button>
              <a class="btn btn-ghost w-100" href="/admin/login">Start Over</a>
            </form>
          <% } else if (viewMode === 'forgot-password') { %>
            <form method="post" action="/admin/forgot-password" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div>
                <label class="form-label">Admin Email</label>
                <input class="form-control" type="email" name="email" value="<%= forgotEmail %>" placeholder="admin@example.com" autocomplete="email" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Send Reset OTP</button>
              <a class="btn btn-ghost w-100" href="/admin/login">Back to Login</a>
            </form>
          <% } else if (viewMode === 'verify-reset-otp') { %>
            <form method="post" action="/admin/verify-reset-otp" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div>
                <label class="form-label">Admin Email</label>
                <input class="form-control" type="email" name="email" value="<%= forgotEmail %>" placeholder="admin@example.com" autocomplete="email" required />
              </div>
              <div>
                <label class="form-label">6-Digit OTP</label>
                <input class="form-control" type="text" name="otp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" autocomplete="one-time-code" autocapitalize="off" autocorrect="off" spellcheck="false" enterkeyhint="done" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Verify OTP</button>
              <a class="btn btn-ghost w-100" href="/admin/login?mode=forgot-password">Request New OTP</a>
            </form>
          <% } else if (viewMode === 'reset-password') { %>
            <form method="post" action="/admin/reset-password" class="d-grid gap-3 auth-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="resetToken" value="<%= resetToken %>" />
              <div>
                <label class="form-label">New Password</label>
                <input class="form-control" type="password" name="password" placeholder="Use uppercase, lowercase, and a number" autocomplete="new-password" required />
              </div>
              <div>
                <label class="form-label">Confirm Password</label>
                <input class="form-control" type="password" name="confirmPassword" placeholder="Repeat your new password" autocomplete="new-password" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Update Password</button>
              <a class="btn btn-ghost w-100" href="/admin/login">Back to Login</a>
            </form>
          <% } else { %>
            <form method="post" action="/admin/login" class="d-grid gap-3 auth-form auth-form--login">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="returnTo" value="<%= returnTo %>" />

              <div>
                <label class="form-label">Email</label>
                <div class="auth-input">
                  <span class="auth-input__icon" aria-hidden="true">✉</span>
                  <input class="form-control auth-input__control" type="email" name="email" value="<%= email %>" placeholder="admin@example.com" autocomplete="username" required />
                </div>
              </div>
              <div>
                <label class="form-label">Password</label>
                <div class="auth-input auth-input--password">
                  <span class="auth-input__icon" aria-hidden="true">•</span>
                  <input class="form-control auth-input__control" type="password" name="password" placeholder="••••••••••" autocomplete="current-password" data-password-input required />
                  <button class="auth-input__toggle" type="button" data-password-toggle aria-label="Show password">Show</button>
                </div>
              </div>

              <button class="btn btn-primary w-100" type="submit">Login</button>
              <button class="btn btn-outline-light w-100" type="button" data-passkey-login>Login with Passkey / QR</button>
              <a class="btn btn-outline-light w-100" href="/admin/login?mode=authenticator-start">Login with Authenticator</a>
              <a class="auth-inline-link text-center" href="/admin/login?mode=forgot-password">Forgot Password</a>
            </form>
          <% } %>
        </aside>
      </div>
    </main>
    <%- include('../partials/footer') %>
    <script src="/assets/js/admin-login.js"></script>
  </body>
</html>
