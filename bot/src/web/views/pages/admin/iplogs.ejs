<!doctype html>
<html lang="en">
  <head>
    <%- include('../../partials/head', { title }) %>
  </head>
  <body class="bg-light">
    <%- include('../../partials/nav') %>
    <main class="container py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h4 m-0">IP Logs</h1>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/verification/settings">Back</a>
      </div>

      <div class="alert alert-warning">
        Admin-only: IP logs may contain personal data. Keep this private and follow your local privacy laws.
      </div>

      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead>
            <tr>
              <th>IP</th>
              <th>User</th>
              <th>Count</th>
              <th>Last Seen</th>
              <th>Flag</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(l => { %>
              <tr class="<%= l.flagged ? 'table-warning' : '' %>">
                <td><code><%= l.ip %></code></td>
                <td><%= l.discordId ? l.discordId : '(visit only)' %></td>
                <td><%= l.count %></td>
                <td class="text-muted small"><%= new Date(l.lastSeenAt).toISOString() %></td>
                <td><%= l.flagged ? (l.flaggedReason || 'flagged') : '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </body>
</html>

