# IMPORTANT: Do NOT put real tokens/secrets in this file.
# Copy to `.env` and fill out values locally.

# DISCORD BOT TOKENS (3 separate bots, shared DB)
ECONOMY_DISCORD_TOKEN=
BACKUP_DISCORD_TOKEN=
VERIFICATION_DISCORD_TOKEN=

# BOT APPLICATION IDS (for slash command registration scripts)
ECONOMY_CLIENT_ID=
BACKUP_CLIENT_ID=
VERIFICATION_CLIENT_ID=

# DASHBOARD OAUTH2 (usually use the Verification bot application)
CLIENT_ID=
CLIENT_SECRET=
CALLBACK_URL=http://localhost:3000/auth/discord/callback

# DATABASE
# Existing app configuration uses MONGODB_URI.
MONGODB_URI=mongodb://localhost:27017/bot

# SESSION / WEB
SESSION_SECRET=
PORT=3000
NODE_ENV=development
TRUST_PROXY=false
# If behind a reverse proxy/CDN (Render, Cloudflare), set to 1
PUBLIC_BASE_URL=http://localhost:3000

# OPTIONAL: MODULE WEBHOOK URLS (Discord incoming webhooks)
VERIFICATION_WEBHOOK_URL=
BACKUP_WEBHOOK_URL=
ECONOMY_WEBHOOK_URL=

# OPTIONAL: force backups onto a stable directory or mounted disk path
# Example (Windows): BACKUP_STORAGE_DIR=C:\bot-data\backups
# Example (Linux/Render disk): BACKUP_STORAGE_DIR=/var/data/rodstarkian/backups
# Leave blank to use the app default location, but note that some deploy platforms wipe local files on redeploy.
BACKUP_STORAGE_DIR=

# OPTIONAL: LOG TOGGLES (true/false)
LOG_JOINS=true
LOG_LEAVES=true
LOG_DELETES=true
LOG_EDITS=true
LOG_BANS=true
LOG_VERIFICATIONS=true
LOG_NICKNAMES=true
LOG_BACKUPS=true
LOG_ECONOMY=true

# OPTIONAL: ECONOMY TUNING
BANK_INTEREST_RATE=0.01
BANK_INTEREST_CRON=0 */12 * * *
DAILY_BASE=1000
DAILY_STREAK_BONUS=100

# OPTIONAL: ECONOMY TEXT PREFIX (message commands like "robo balance")
# NOTE: Requires enabling "Message Content Intent" for the Economy bot in the Discord Developer Portal.
ECONOMY_TEXT_PREFIX=robo

# OPTIONAL: ECONOMY ACCOUNT SCOPE
# - global: one shared wallet/bank/inventory across all servers (recommended)
# - guild: separate account per server
ECONOMY_ACCOUNT_SCOPE=global

# OPTIONAL: Emoji source servers (comma-separated guild IDs)
# Bot must be inside these guilds for external emoji IDs to render everywhere.
EMOJI_SOURCE_GUILD_IDS=
# Optional: explicit source guild used for auto-uploaded item emojis.
# Leave blank to fall back to the first EMOJI_SOURCE_GUILD_IDS entry.
ECONOMY_ITEM_EMOJI_GUILD_ID=

# NOTE: Emoji seeding is disabled in code (static emoji IDs only).
# These are kept for backward compatibility but are ignored.
ECONOMY_SEED_EMOJIS=false
ECONOMY_ALLOW_EXTERNAL_EMOJIS=false
ECONOMY_EMOJI_ASSETS_DIR=images/emojis

# OPTIONAL: Force a global footer icon URL for economy game result embeds
# (used when custom emoji is unavailable or server emoji slots are full)
ECONOMY_BRAND_ICON_URL=

# OPTIONAL: DEV COMMAND REGISTRATION (instant updates)
DEV_GUILD_ID=

# OPTIONAL: ONE-TIME ADMIN BOOTSTRAP (only if no admins exist)
# These create the FIRST admin account in MongoDB.
# Use the REAL admin email you want to log in with.
# Set these in Render, deploy once, then remove them after the first successful login.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ADMIN AUTH / SECURITY
# Optional comma-separated allowlist used for first-owner setup / bootstrap.
# Owner-created admin accounts are stored in MongoDB and can log in even if not listed here.
# Example: ADMIN_ALLOWED_EMAILS=rdskbots@gmail.com
# Leave blank only if you are still bootstrapping.
ADMIN_ALLOWED_EMAILS=owner@example.com,admin@example.com
# Use a long random value in production.
JWT_SECRET=replace_with_a_long_random_secret
# Gmail SMTP / Nodemailer
# These are ONLY for sending forgot-password / reset OTP emails.
# EMAIL_PASS must be a Gmail APP PASSWORD, not the admin login password.
EMAIL_USER=rdskbots@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=rdskbots@gmail.com
# Timezone used in dashboard-generated dates like password reset emails.
# Example: Asia/Manila
APP_TIMEZONE=Asia/Manila
# Google Authenticator issuer label
ADMIN_TOTP_ISSUER=Rodstarkian Suite
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOCK_MINUTES=15
ADMIN_AUTH_COOKIE_NAME=admin_token

# OPTIONAL: SEED SHOP LISTINGS (guild to seed shop items into)
SEED_GUILD_ID=
